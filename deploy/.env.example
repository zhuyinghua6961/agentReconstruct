# Docker 部署配置示例。正式交付建议从 .env.production.example 复制。

HTTP_PUBLISH_PORT=80
HTTPS_PUBLISH_PORT=443
HTTPS_SERVER_NAME=lifeo4.agent.test
HTTPS_REDIRECT_HOST=lifeo4.agent.test

FRONTEND_PUBLISH_PORT=8080
MYSQL_PUBLISH_PORT=3306
REDIS_PUBLISH_PORT=6379
MINIO_API_PUBLISH_PORT=9000
MINIO_CONSOLE_PUBLISH_PORT=9001

MYSQL_ROOT_PASSWORD=change_me_mysql_root
MYSQL_APP_USER=agentcode
MYSQL_APP_PASSWORD=change_me_mysql_app
REDIS_PASSWORD=change_me_redis

MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=change_me_minio
MINIO_BUCKET=agentcode
MINIO_REGION=us-east-1

DATA_PACKAGE_VERSION=2026-05-19
DATA_SEED_FORCE=0

JWT_SECRET=change_me_jwt_secret
PUBLIC_SERVICE_INTERNAL_AUTH_TOKEN=change_me_internal_token

LLM_API_KEY=
LLM_AUTH_MODE=bearer
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3-max
LLM_IS_THINKING_MODEL=false
LLM_THINKING_ENABLED=false

INTENT_MODEL_ENABLED=false
INTENT_MODEL_API_KEY=
INTENT_MODEL_AUTH_MODE=
INTENT_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
INTENT_MODEL=qwen3-8b
INTENT_MODEL_TIMEOUT_SECONDS=30

QA_EMBEDDING_API_KEY=
QA_EMBEDDING_AUTH_MODE=bearer
QA_EMBEDDING_BASE_URL=http://embedding-service:8001/v1
QA_EMBEDDING_MODEL=bge-local

HIGHTHINKINGQA_EMBEDDING_API_KEY=
HIGHTHINKINGQA_EMBEDDING_AUTH_MODE=none
HIGHTHINKINGQA_EMBEDDING_BASE_URL=http://host.docker.internal:8014/v1
HIGHTHINKINGQA_EMBEDDING_MODEL=qwen3-embedding-8b
HIGHTHINKINGQA_EMBEDDING_DIMENSIONS=4096

RERANK_BASE_URL=
RERANK_MODEL=
RERANK_API_KEY=
RERANK_AUTH_MODE=bearer
