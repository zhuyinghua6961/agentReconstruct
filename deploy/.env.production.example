# Portable production deployment template
# Copy to deploy/.env and replace all placeholder values before release.

COMPOSE_PROJECT_NAME=highthinking
APP_ENV=production

# Image references
GATEWAY_IMAGE=registry.example.com/highthinking/gateway:2026-03-25
PUBLIC_SERVICE_IMAGE=registry.example.com/highthinking/public-service:2026-03-25
FASTQA_IMAGE=registry.example.com/highthinking/fastqa:2026-03-25
HIGHTHINKINGQA_IMAGE=registry.example.com/highthinking/highthinkingqa:2026-03-25
PATENT_IMAGE=registry.example.com/highthinking/patent:2026-03-25
FRONTEND_IMAGE=registry.example.com/highthinking/frontend:2026-03-25

# Infrastructure image tags
MYSQL_IMAGE_TAG=8.0
REDIS_IMAGE_TAG=7
MINIO_IMAGE_TAG=latest
MINIO_MC_IMAGE_TAG=latest
ALPINE_IMAGE_TAG=3.20
NGINX_IMAGE_TAG=1.27-alpine

# Published ports
FRONTEND_PUBLISH_PORT=8080
GATEWAY_PUBLISH_PORT=8101
PUBLIC_SERVICE_PUBLISH_PORT=8102
FASTQA_PUBLISH_PORT=8008
HIGHTHINKINGQA_PUBLISH_PORT=8009
PATENT_PUBLISH_PORT=8010
MYSQL_PUBLISH_PORT=3306
REDIS_PUBLISH_PORT=6379
MINIO_API_PUBLISH_PORT=9000
MINIO_CONSOLE_PUBLISH_PORT=9001

# Docker bridge network
DOCKER_BRIDGE_SUBNET=172.20.0.0/24
DOCKER_BRIDGE_GATEWAY=172.20.0.1

# MySQL
MYSQL_ROOT_PASSWORD=replace_with_real_mysql_root_password
MYSQL_DATABASE=agentcode
MYSQL_APP_USER=root
MYSQL_APP_PASSWORD=replace_with_real_mysql_app_password

# Redis
REDIS_PASSWORD=replace_with_real_redis_password

# Shared auth
JWT_SECRET=replace_with_real_jwt_secret
PUBLIC_SERVICE_INTERNAL_AUTH_TOKEN=replace_with_real_internal_service_token

# MinIO
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=replace_with_real_minio_password
MINIO_BUCKET=agentcode
MINIO_REGION=us-east-1

# Model connections
LLM_API_KEY=replace_with_real_llm_key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3-max

# fastQA and patentQA share this embedding endpoint.
# Use the full embedding endpoint URL, for example /v1/embeddings.
QA_EMBEDDING_MODEL_TYPE=remote
QA_EMBEDDING_API_KEY=
QA_EMBEDDING_BASE_URL=http://127.0.0.1:8001/v1/embeddings
QA_EMBEDDING_MODEL=bge-local

# highThinkingQA uses an independent embedding endpoint.
# Use the OpenAI-compatible base URL, usually /v1.
HIGHTHINKINGQA_EMBEDDING_API_KEY=
HIGHTHINKINGQA_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
HIGHTHINKINGQA_EMBEDDING_MODEL=text-embedding-v4

# fastQA and patentQA share this rerank endpoint.
# RERANK_PROVIDER can be local, dashscope, none, off, or disabled.
RERANK_PROVIDER=none
RERANK_BASE_URL=
RERANK_MODEL=qwen3-vl-rerank
RERANK_API_KEY=

# public-service
PUBLIC_SERVICE_CORS_ORIGINS=*
PUBLIC_SERVICE_REDIS_ENABLED=1
PUBLIC_SERVICE_REDIS_DB=0
PUBLIC_SERVICE_REDIS_KEY_PREFIX=public_service
PUBLIC_SERVICE_MINIO_USE_PROXY=1
PUBLIC_SERVICE_MINIO_DOWNLOAD_EXPIRES=3600
PUBLIC_SERVICE_NEO4J_URL=
PUBLIC_SERVICE_NEO4J_USERNAME=neo4j
PUBLIC_SERVICE_NEO4J_PASSWORD=

# fastQA
FASTQA_REDIS_ENABLED=1
FASTQA_REDIS_DB=0
FASTQA_REDIS_KEY_PREFIX=fastqa
FASTQA_PDFQA_SIDECAR_BASE_URL_INTERNAL=http://127.0.0.1:8012

# highThinkingQA
HIGHTHINKINGQA_REDIS_ENABLED=1
HIGHTHINKINGQA_REDIS_DB=0
HIGHTHINKINGQA_REDIS_KEY_PREFIX=highthinkingqa

# patentQA
PATENT_GUNICORN_WORKERS=4
PATENT_GUNICORN_THREADS=8
PATENT_GUNICORN_TIMEOUT=600
PATENT_REDIS_ENABLED=1
PATENT_REDIS_DB=0
PATENT_REDIS_KEY_PREFIX=patent
PATENT_GRAPH_KB_ENABLED=1
PATENT_GRAPH_KB_V2_ENABLED=1
PATENT_GRAPH_KB_RAG_INJECTION_ENABLED=1
PATENT_NEO4J_URL=bolt://neo4j-host:7687
PATENT_NEO4J_USERNAME=neo4j
PATENT_NEO4J_PASSWORD=replace_with_real_patent_neo4j_password
PATENT_NEO4J_DATABASE=neo4j

# gateway
GATEWAY_CONVERSATION_FILE_PROVIDER=public_http
GATEWAY_REQUEST_TIMEOUT_SECONDS=30
GATEWAY_SSE_TIMEOUT_SECONDS=600
