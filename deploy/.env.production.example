# Docker 生产部署配置模板
# 复制为 deploy/.env 后填写真实值。客户主配置面只保留端口、账号、模型连接和数据包版本。

# ============================================================================
# 1. 对外访问端口
# ============================================================================
HTTP_PUBLISH_PORT=80
HTTPS_PUBLISH_PORT=443
# HTTPS_SERVER_NAME 必须和部署方证书 SAN 中的域名一致。
HTTPS_SERVER_NAME=replace_with_real_domain
# 标准 443 端口通常填写同一个域名；若映射到非标准端口，可填 domain:port。
HTTPS_REDIRECT_HOST=replace_with_real_domain

FRONTEND_PUBLISH_PORT=8080
MYSQL_PUBLISH_PORT=3306
REDIS_PUBLISH_PORT=6379
MINIO_API_PUBLISH_PORT=9000
MINIO_CONSOLE_PUBLISH_PORT=9001

# ============================================================================
# 2. MySQL / Redis / MinIO
# ============================================================================
MYSQL_ROOT_PASSWORD=replace_with_real_mysql_root_password
MYSQL_APP_USER=agentcode
MYSQL_APP_PASSWORD=replace_with_real_mysql_app_password

REDIS_PASSWORD=replace_with_real_redis_password

MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=replace_with_real_minio_password
MINIO_BUCKET=agentcode
MINIO_REGION=us-east-1

# ============================================================================
# 3. 离线数据包
# ============================================================================
# deploy/data/manifest.json 中记录同一批数据包的版本；同版本 seed 已完成时会跳过。
DATA_PACKAGE_VERSION=2026-05-19
# 设为 1 时强制重新导入 MinIO originals、reference data 和 Neo4j dump。
DATA_SEED_FORCE=0

# ============================================================================
# 4. 业务鉴权密钥
# ============================================================================
JWT_SECRET=replace_with_real_jwt_secret
PUBLIC_SERVICE_INTERNAL_AUTH_TOKEN=replace_with_real_internal_service_token

# ============================================================================
# 5. LLM 大模型连接
# ============================================================================
LLM_API_KEY=replace_with_real_llm_key
LLM_AUTH_MODE=bearer
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3-max
LLM_IS_THINKING_MODEL=false
LLM_THINKING_ENABLED=false

# ============================================================================
# 6. fastQA 和 patentQA 共用 intent 模型连接
# ============================================================================
INTENT_MODEL_ENABLED=false
INTENT_MODEL_API_KEY=
INTENT_MODEL_AUTH_MODE=
INTENT_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
INTENT_MODEL=qwen3-8b
INTENT_MODEL_TIMEOUT_SECONDS=30

# ============================================================================
# 7. fastQA / patentQA 阶段一诊断日志
# ============================================================================
# 默认记录阶段一原始回答预览；设为 1 时记录完整原始回答，排查完成后建议恢复为 0。
QA_STAGE1_LOG_RESPONSE_MAX_CHARS=4000
QA_STAGE1_LOG_FULL_RESPONSE=0
# 阶段二诊断：记录最终 embedding query、编码状态、召回 top hits、过滤前后与汇总。
QA_STAGE2_DIAGNOSTIC_LOG=1
QA_STAGE2_LOG_QUERY_DETAILS=1
QA_STAGE2_LOG_HIT_DETAILS=1
QA_STAGE2_LOG_HIT_MAX=5
QA_STAGE2_LOG_QUERY_MAX_CHARS=1000
# 阶段三诊断：记录 DOI/source_id 到原文/PDF/table/chunk 证据包的组装过程。
QA_STAGE3_DIAGNOSTIC_LOG=1
QA_STAGE3_LOG_SOURCE_DETAILS=1
QA_STAGE3_LOG_CHUNK_DETAILS=1
QA_STAGE3_LOG_CHUNK_MAX=5
QA_STAGE3_LOG_TEXT_MAX_CHARS=1000
FASTQA_STAGE2_CHAT_WARMUP_ENABLED=false
FASTQA_STAGE2_RERANK_WARMUP_ENABLED=false
PDF_QA_WARMUP_ENABLED=0
PATENT_PLANNING_HOT_POOL_WARMUP_ENABLED=false

# ============================================================================
# 8. fastQA 和 patentQA 共用 embedding 连接
# ============================================================================
QA_EMBEDDING_API_KEY=
QA_EMBEDDING_AUTH_MODE=bearer
QA_EMBEDDING_BASE_URL=http://embedding-service:8001/v1
QA_EMBEDDING_MODEL=bge-local

# ============================================================================
# 9. highThinkingQA 独立 embedding 连接
# ============================================================================
HIGHTHINKINGQA_EMBEDDING_API_KEY=
HIGHTHINKINGQA_EMBEDDING_AUTH_MODE=bearer
HIGHTHINKINGQA_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
HIGHTHINKINGQA_EMBEDDING_MODEL=text-embedding-v4

# ============================================================================
# 10. fastQA 和 patentQA 共用 rerank 连接
# ============================================================================
RERANK_BASE_URL=
RERANK_MODEL=
RERANK_API_KEY=
RERANK_AUTH_MODE=bearer

# ============================================================================
# 11. 高级镜像覆盖项，只有镜像 tag 与默认值不一致时才取消注释
# ============================================================================
# GATEWAY_IMAGE=lifeo4agent/gateway:latest
# PUBLIC_SERVICE_IMAGE=lifeo4agent/public-service:latest
# FASTQA_IMAGE=lifeo4agent/fastqa:latest
# HIGHTHINKINGQA_IMAGE=lifeo4agent/highthinkingqa:latest
# PATENT_IMAGE=lifeo4agent/patent:latest
# FRONTEND_IMAGE=lifeo4agent/frontend:latest
# SEED_TOOLS_IMAGE=lifeo4agent/seed-tools:latest
# NEO4J_IMAGE_TAG=5.26.12
