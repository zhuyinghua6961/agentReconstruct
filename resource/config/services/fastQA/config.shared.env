# Public runtime defaults for fastQA
# Service-config load order: config.env -> config.shared.env -> config.secret.env -> .env

# 中文: APP_ENV：运行模式、命名或路由标识。
APP_ENV=development
# 中文: LOG_LEVEL：应用日志级别，例如 INFO、DEBUG、WARNING。
LOG_LEVEL=INFO
# 中文: FASTQA_GUNICORN_WORKERS：快速问答服务：并发 worker 或线程配置。
FASTQA_GUNICORN_WORKERS=8
# 中文: BACKEND_CORS_ORIGINS：跨域访问：允许访问的前端来源列表。
BACKEND_CORS_ORIGINS=*

# Ask / SSE
# 中文: ASK_STREAM_MAX_CONCURRENT：数量、容量或并发限制。
ASK_STREAM_MAX_CONCURRENT=20
# 中文: SSE_HEARTBEAT_SEC：通用配置项。
SSE_HEARTBEAT_SEC=15
# 中文: FASTQA_ENABLE_FILE_CONTEXT_FALLBACK：快速问答服务：功能开关，使用 1/0、true/false 控制。
FASTQA_ENABLE_FILE_CONTEXT_FALLBACK=1
# 中文: FASTQA_ALLOW_PLACEHOLDER_FALLBACK：快速问答服务：功能开关，使用 1/0、true/false 控制。
FASTQA_ALLOW_PLACEHOLDER_FALLBACK=1
# 中文: FASTQA_GENERATION_RUNTIME_ENABLED：快速问答服务：功能开关，使用 1/0、true/false 控制。
FASTQA_GENERATION_RUNTIME_ENABLED=1
# 中文: FASTQA_GRAPH_KB_TIMEOUT_MS：快速问答服务：超时时间配置。
FASTQA_GRAPH_KB_TIMEOUT_MS=3000
# 中文: FASTQA_GRAPH_KB_MAX_ROWS：快速问答服务：数量、容量或并发限制。
FASTQA_GRAPH_KB_MAX_ROWS=20
# 中文: FASTQA_GRAPH_KB_QUERY_LOGGING：快速问答服务：功能开关，使用 1/0、true/false 控制。
FASTQA_GRAPH_KB_QUERY_LOGGING=0
# 中文: FASTQA_GRAPH_DIRECT_ANSWER_MIN_CONFIDENCE：fastQA 图谱直答所需的最低置信度。
FASTQA_GRAPH_DIRECT_ANSWER_MIN_CONFIDENCE=0.8
# 中文: FASTQA_GRAPH_MAX_DOI_CANDIDATES：fastQA 图谱候选 DOI 的最大数量。
FASTQA_GRAPH_MAX_DOI_CANDIDATES=20
# 中文: FASTQA_GRAPH_ALLOW_SUSPICIOUS_DOI_FOR_RAG：快速问答服务：通用配置项。
FASTQA_GRAPH_ALLOW_SUSPICIOUS_DOI_FOR_RAG=0

# Model / transport
# 中文: FASTQA_LLM_HTTP_SHARED_POOL_ENABLED：快速问答服务：功能开关，使用 1/0、true/false 控制。
FASTQA_LLM_HTTP_SHARED_POOL_ENABLED=1

# Embedding / retrieval
# 中文: EMBEDDING_MODEL_PATH：向量嵌入：本地目录、文件或资源根路径。
EMBEDDING_MODEL_PATH=/home/cqy/worktrees/highThinking/resource/fastqa/models/bge_model
# 中文: VECTOR_DB_PATH：向量库：本地目录、文件或资源根路径。
VECTOR_DB_PATH=/home/cqy/worktrees/highThinking/resource/fastqa/vector_database
# 中文: VECTOR_DB_SUMMARY_PATH：向量库：本地目录、文件或资源根路径。
VECTOR_DB_SUMMARY_PATH=/home/cqy/worktrees/highThinking/resource/fastqa/vector_database
# 中文: VECTOR_DB_PDF_PATH：向量库：本地目录、文件或资源根路径。
VECTOR_DB_PDF_PATH=/home/cqy/worktrees/highThinking/resource/fastqa/vector_database_pdf
# 中文: VECTOR_DB_COMMUNITY_PATH：向量库：本地目录、文件或资源根路径。
VECTOR_DB_COMMUNITY_PATH=/home/cqy/worktrees/highThinking/resource/fastqa/community_vector_database
# 中文: VECTOR_DB_MD_PATH：向量库：本地目录、文件或资源根路径。
VECTOR_DB_MD_PATH=/home/cqy/worktrees/highThinking/resource/fastqa/vector_database_md
# 中文: VECTOR_DB_MD_COLLECTION：向量库：通用配置项。
VECTOR_DB_MD_COLLECTION=md_papers
# 中文: TOPIC_INDEX_PATH：本地目录、文件或资源根路径。
TOPIC_INDEX_PATH=/home/cqy/worktrees/highThinking/resource/fastqa/vector_db_topic_index.json

# Data directories
# 中文: JSON_DIR：本地目录、文件或资源根路径。
JSON_DIR=/home/cqy/worktrees/highThinking/resource/fastqa/json
# 中文: JSON_NORMALIZED_DIR：本地目录、文件或资源根路径。
JSON_NORMALIZED_DIR=/home/cqy/worktrees/highThinking/resource/fastqa/json_normalized
# 中文: PAPERS_DIR：本地目录、文件或资源根路径。
PAPERS_DIR=/home/cqy/worktrees/highThinking/resource/fastqa/papers
# 中文: PDF_CHUNKS_DIR：本地目录、文件或资源根路径。
PDF_CHUNKS_DIR=/home/cqy/worktrees/highThinking/resource/fastqa/pdf_chunks
# 中文: JSON_SUMMARY_DIR：本地目录、文件或资源根路径。
JSON_SUMMARY_DIR=/home/cqy/worktrees/highThinking/resource/fastqa/json_summary
# 中文: TRANSLATION_CACHE_DIR：本地目录、文件或资源根路径。
TRANSLATION_CACHE_DIR=/home/cqy/worktrees/highThinking/resource/fastqa/translation_cache
# 中文: CHAT_JSON_BASE_DIR：对话存储：本地目录、文件或资源根路径。
CHAT_JSON_BASE_DIR=/home/cqy/worktrees/highThinking/resource/fastqa/data/conversations
# 中文: MATERIAL_AGENT_PROMPTS_DIR：本地目录、文件或资源根路径。
MATERIAL_AGENT_PROMPTS_DIR=/home/cqy/worktrees/highThinking/resource/fastqa/prompts

# Generation pipeline
# 中文: QA_QUERY_PIPELINE_MODE：fastQA 问答检索流水线模式。
QA_QUERY_PIPELINE_MODE=new
# 中文: QA_RETRIEVAL_RERANK_CANDIDATES：QA 流水线：数量、容量或并发限制。
QA_RETRIEVAL_RERANK_CANDIDATES=50
# 中文: QA_STAGE2_PARALLEL_WORKERS：QA 流水线：并发 worker 或线程配置。
QA_STAGE2_PARALLEL_WORKERS=5
# 中文: QA_STAGE2_DYNAMIC_WORKERS_ENABLED：QA 流水线：功能开关，使用 1/0、true/false 控制。
QA_STAGE2_DYNAMIC_WORKERS_ENABLED=false
# 中文: QA_STAGE2_DYNAMIC_WORKERS_TRIGGER_ACTIVE：QA 流水线：通用配置项。
QA_STAGE2_DYNAMIC_WORKERS_TRIGGER_ACTIVE=4
# 中文: QA_STAGE2_DYNAMIC_WORKERS_MIN：QA 流水线：通用配置项。
QA_STAGE2_DYNAMIC_WORKERS_MIN=3
# 中文: QA_STAGE2_DYNAMIC_WORKERS_STEP：QA 流水线：通用配置项。
QA_STAGE2_DYNAMIC_WORKERS_STEP=1
# 中文: QA_STREAM_CLEAN_FLUSH_CHARS：流式回答清洗后累计多少字符触发一次输出刷新。
QA_STREAM_CLEAN_FLUSH_CHARS=384
# 中文: QA_STAGE2_QUERY_EXPANSION_ENABLED：QA 流水线：功能开关，使用 1/0、true/false 控制。
QA_STAGE2_QUERY_EXPANSION_ENABLED=false
# 中文: QA_STAGE2_RETRIEVAL_VERSION：QA 流水线：通用配置项。
QA_STAGE2_RETRIEVAL_VERSION=1
# 中文: QA_STAGE1_CACHE_TTL_SECONDS：QA 流水线：缓存或凭证有效期。
QA_STAGE1_CACHE_TTL_SECONDS=43200
# 中文: QA_STAGE2_CACHE_TTL_SECONDS：QA 流水线：缓存或凭证有效期。
QA_STAGE2_CACHE_TTL_SECONDS=43200
# 中文: QA_STAGE25_CACHE_TTL_SECONDS：QA 流水线：缓存或凭证有效期。
QA_STAGE25_CACHE_TTL_SECONDS=43200
# 中文: QA_SOURCE_DOI_MAX_TOTAL：QA 流水线：数量、容量或并发限制。
QA_SOURCE_DOI_MAX_TOTAL=15
# 中文: QA_SOURCE_DOI_MAX_TOTAL_NON_COMPARISON：QA 流水线：数量、容量或并发限制。
QA_SOURCE_DOI_MAX_TOTAL_NON_COMPARISON=20
# 中文: QA_SOURCE_DOI_MAX_PER_COMPARISON_OBJECT：QA 流水线：数量、容量或并发限制。
QA_SOURCE_DOI_MAX_PER_COMPARISON_OBJECT=5
# 中文: QA_STAGE3_CACHE_TTL_SECONDS：QA 流水线：缓存或凭证有效期。
QA_STAGE3_CACHE_TTL_SECONDS=43200
# 中文: QA_STAGE25_MD_MAX_DOIS：QA 流水线：数量、容量或并发限制。
QA_STAGE25_MD_MAX_DOIS=20
# 中文: QA_STAGE25_MD_CHUNKS_PER_DOI：QA 流水线：通用配置项。
QA_STAGE25_MD_CHUNKS_PER_DOI=5
# 中文: QA_STAGE25_MD_GLOBAL_SUPPLEMENT_ENABLED：QA 流水线：功能开关，使用 1/0、true/false 控制。
QA_STAGE25_MD_GLOBAL_SUPPLEMENT_ENABLED=true
# 中文: QA_STAGE25_MD_GLOBAL_TOPK：QA 流水线：数量、容量或并发限制。
QA_STAGE25_MD_GLOBAL_TOPK=20
# 中文: QA_STAGE25_MD_GLOBAL_MAX_NEW_DOIS：QA 流水线：数量、容量或并发限制。
QA_STAGE25_MD_GLOBAL_MAX_NEW_DOIS=5
# 中文: QA_STAGE25_MD_GLOBAL_MIN_SCORE：QA 流水线：数量、容量或并发限制。
QA_STAGE25_MD_GLOBAL_MIN_SCORE=0
# 中文: QA_STAGE35_EVIDENCE_RERANK_ENABLED：QA 流水线：功能开关，使用 1/0、true/false 控制。
QA_STAGE35_EVIDENCE_RERANK_ENABLED=true
# 中文: QA_STAGE35_EVIDENCE_TOPK_TOTAL：QA 流水线：数量、容量或并发限制。
QA_STAGE35_EVIDENCE_TOPK_TOTAL=30
# 中文: QA_STAGE35_EVIDENCE_TOPK_PER_DOI：QA 流水线：通用配置项。
QA_STAGE35_EVIDENCE_TOPK_PER_DOI=3
# 中文: QA_STAGE35_EVIDENCE_TOPK_PER_COMPARISON_OBJECT：QA 流水线：通用配置项。
QA_STAGE35_EVIDENCE_TOPK_PER_COMPARISON_OBJECT=8
# 中文: QA_STAGE4_REFERENCE_TOPK：QA 流水线：数量、容量或并发限制。
QA_STAGE4_REFERENCE_TOPK=20
# 中文: QA_STAGE4_MIN_CITATIONS：QA 流水线：数量、容量或并发限制。
QA_STAGE4_MIN_CITATIONS=4
# 中文: QA_STAGE4_ELEMENT_GUARD：QA 流水线：通用配置项。
QA_STAGE4_ELEMENT_GUARD=true
# false：不做 DOI 与 PDF/事实列表 的一致性清洗，且关闭程序化补 DOI 与空引用时的 align 回退
# 中文: QA_STAGE4_CITATION_VERIFY_AFTER_SYNTHESIS：QA 流水线：通用配置项。
QA_STAGE4_CITATION_VERIFY_AFTER_SYNTHESIS=false
# 中文: QA_STAGE4_TWO_STAGE_SYNTHESIS_ENABLED：QA 流水线：功能开关，使用 1/0、true/false 控制。
QA_STAGE4_TWO_STAGE_SYNTHESIS_ENABLED=true
# true：按 DOI 分段调用事实抽取再合并，利于多篇不同 doi 进入事实列表（LLM 调用次数随 DOI 数增加）
# 中文: QA_STAGE4_FACT_EXTRACTION_PER_DOI_ENABLED：QA 流水线：功能开关，使用 1/0、true/false 控制。
QA_STAGE4_FACT_EXTRACTION_PER_DOI_ENABLED=true
# 中文: QA_STAGE4_FACT_PER_DOI_MAX_DOIS：QA 流水线：数量、容量或并发限制。
QA_STAGE4_FACT_PER_DOI_MAX_DOIS=10
# 中文: QA_STAGE4_FACT_PER_DOI_MAX_MERGED_CARDS：QA 流水线：数量、容量或并发限制。
QA_STAGE4_FACT_PER_DOI_MAX_MERGED_CARDS=48
# 0 表示与 QA_STAGE4_FACT_EXTRACTION_MAX_TOKENS 相同；可按需降低单次分段成本
# 中文: QA_STAGE4_FACT_PER_DOI_EXTRACTION_MAX_TOKENS：QA 流水线：敏感凭据，填写真实密钥、令牌或密码。
QA_STAGE4_FACT_PER_DOI_EXTRACTION_MAX_TOKENS=0
# 中文: QA_STAGE4_FACT_EXTRACTION_MAX_TOKENS：QA 流水线：敏感凭据，填写真实密钥、令牌或密码。
QA_STAGE4_FACT_EXTRACTION_MAX_TOKENS=1200
# 事实列表≥3 个不同 DOI 时 Stage4 流式合成温度（越低越倾向遵守多篇引用约束）
# 中文: QA_STAGE4_FACT_MULTI_DOI_STREAM_TEMPERATURE：QA 流水线：模型采样或评分阈值。
QA_STAGE4_FACT_MULTI_DOI_STREAM_TEMPERATURE=0.12
# 为 true 时：事实/受限合成提示中注入阶段一 deep_answer（仅作结构/角度/衔接，非事实源），对齐旧版专家初稿参与方式
# 中文: QA_STAGE4_FACT_SYNTHESIS_INCLUDE_DEEP_ANSWER：QA 流水线：通用配置项。
QA_STAGE4_FACT_SYNTHESIS_INCLUDE_DEEP_ANSWER=true
# 0 表示不截断；否则按字符数截断预回答再注入
# 中文: QA_STAGE4_EXPERT_DRAFT_MAX_CHARS：QA 流水线：数量、容量或并发限制。
QA_STAGE4_EXPERT_DRAFT_MAX_CHARS=12000
# 中文: QA_STAGE4_REQUIRE_FACTS_FOR_DOI_SYNTHESIS：QA 流水线：通用配置项。
QA_STAGE4_REQUIRE_FACTS_FOR_DOI_SYNTHESIS=true
# 中文: QA_STAGE4_EMPTY_FACTS_FALLBACK_MODE：Stage4 无事实卡片时采用的降级生成模式。
QA_STAGE4_EMPTY_FACTS_FALLBACK_MODE=restricted_synthesis
# 中文: QA_STAGE4_STRUCTURE_ONLY_MODE：QA 流水线：运行模式、命名或路由标识。
QA_STAGE4_STRUCTURE_ONLY_MODE=false
# 中文: QA_STAGE4_EVIDENCE_CHUNKS_PER_DOI：QA 流水线：通用配置项。
QA_STAGE4_EVIDENCE_CHUNKS_PER_DOI=3
# 中文: QA_STAGE4_EVIDENCE_CHUNK_MAX_CHARS：QA 流水线：数量、容量或并发限制。
QA_STAGE4_EVIDENCE_CHUNK_MAX_CHARS=800
# 中文: QA_STAGE3_SKIP_PDF_WHEN_MD_HIT：QA 流水线：通用配置项。
QA_STAGE3_SKIP_PDF_WHEN_MD_HIT=false
# 中文: QA_STAGE3_SKIP_PDF_MIN_MD_HIT_DOIS：QA 流水线：数量、容量或并发限制。
QA_STAGE3_SKIP_PDF_MIN_MD_HIT_DOIS=1
# 中文: QA_STAGE3_SKIP_PDF_MIN_MD_CHUNKS：QA 流水线：数量、容量或并发限制。
QA_STAGE3_SKIP_PDF_MIN_MD_CHUNKS=3

# PDF / file QA
# 中文: PDF_QA_MAX_PDF_CHARS：数量、容量或并发限制。
PDF_QA_MAX_PDF_CHARS=50000
# 中文: UPLOAD_QA_FIRST_TOKEN_TIMEOUT_SEC：文件上传：敏感凭据，填写真实密钥、令牌或密码。
UPLOAD_QA_FIRST_TOKEN_TIMEOUT_SEC=60
# 中文: UPLOAD_QA_SIDECAR_MODE：上传文件问答 sidecar 调用模式。
UPLOAD_QA_SIDECAR_MODE=file_only
# 中文: PDFQA_SIDECAR_BASE_URL_INTERNAL：通用配置项。
PDFQA_SIDECAR_BASE_URL_INTERNAL=http://127.0.0.1:8012
# 中文: PDFQA_SIDECAR_SELF_PORT：服务监听或依赖连接端口。
PDFQA_SIDECAR_SELF_PORT=8008
# 中文: PDF_QA_TIMEOUT_SECONDS：超时时间配置。
PDF_QA_TIMEOUT_SECONDS=45
# 中文: PDF_QA_MAX_RETRIES：失败重试次数或重试间隔。
PDF_QA_MAX_RETRIES=0
# 中文: PDF_QA_MAX_TOKENS：敏感凭据，填写真实密钥、令牌或密码。
PDF_QA_MAX_TOKENS=1800
# 中文: PDF_QA_TEMPERATURE：模型采样或评分阈值。
PDF_QA_TEMPERATURE=0.5
# 中文: PDF_QA_TOP_P：模型采样或评分阈值。
PDF_QA_TOP_P=0.95

# Redis defaults
# 中文: REDIS_KEY_PREFIX：Redis 缓存：运行模式、命名或路由标识。
REDIS_KEY_PREFIX=fastqa
