# Commit-safe fastQA defaults (loaded with service config).
# FASTQA_GENERATION_RUNTIME_ENABLED：是否在进程启动时初始化生成流水线（GenerationDrivenRAG、共享 LLM 池、文献专家等）；1 开启（推荐本地/全量 QA）；0 则跳过，日志会出现 generation runtime is disabled。
FASTQA_GENERATION_RUNTIME_ENABLED=1
# FASTQA_LLM_HTTP_SHARED_POOL_ENABLED：是否启用进程内共享 LLM HTTP 连接池（多 worker 共用连接；1 开启）。
FASTQA_LLM_HTTP_SHARED_POOL_ENABLED=1
# Stage2 dense retrieval: after AI query + guardrails, ``finalize_retrieval_keywords_for_embedding``
# builds the string passed to embedding (must_include / injected keywords first).
# QA_STAGE2_EMBEDDING_QUERY_MAX_KEYWORDS：最终进向量的不重复词上限（默认 15，可调大到 24 等做 A/B）。
QA_STAGE2_EMBEDDING_QUERY_MAX_KEYWORDS=15
# QA_STAGE2_EMBEDDING_QUERY_MAX_INJECTION_SLOTS：最多将前 N 条注入/实体锁词强制排在向量串前部；0 表示不限制条数（仍受 MAX_KEYWORDS 约束）。
QA_STAGE2_EMBEDDING_QUERY_MAX_INJECTION_SLOTS=0
# QA_STAGE2_EMBEDDING_QUERY_LLM_REFINE_ENABLED：预留；为 1 时可在未来增加「LLM 压缩检索句」步骤（当前无调用，保持确定性）。
QA_STAGE2_EMBEDDING_QUERY_LLM_REFINE_ENABLED=0
# QA_STAGE2_GRAPH_QUERY_HINT_MERGE_ENABLED：是否把 graph_kb 的实体 hint 追加进 Stage2 审计串（DOI 永不并入检索串）。
QA_STAGE2_GRAPH_QUERY_HINT_MERGE_ENABLED=0
# Stage2→Stage3.5 evidence bridge: prepend Stage2 dense-hit snippets into the PDF/MD chunk map before rerank.
# QA_STAGE2_RETRIEVAL_EVIDENCE_MERGE_ENABLED：1 开启（默认）；0 关闭。
QA_STAGE2_RETRIEVAL_EVIDENCE_MERGE_ENABLED=1
# QA_STAGE2_RETRIEVAL_EVIDENCE_MAX_TOTAL：全局最多并入多少条 Stage2 片段。
QA_STAGE2_RETRIEVAL_EVIDENCE_MAX_TOTAL=40
# QA_STAGE2_RETRIEVAL_EVIDENCE_MAX_PER_DOI：单个 DOI 最多并入多少条 Stage2 片段。
QA_STAGE2_RETRIEVAL_EVIDENCE_MAX_PER_DOI=4
