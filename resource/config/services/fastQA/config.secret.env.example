# Copy to config.secret.env and fill private credentials.

# 中文: LLM_API_KEY：大模型：敏感凭据，填写真实密钥、令牌或密码。
LLM_API_KEY=
# 中文: EMBEDDING_API_KEY：向量嵌入：敏感凭据，填写真实密钥、令牌或密码。
EMBEDDING_API_KEY=
# 中文: NEO4J_PASSWORD / FASTQA_NEO4J_PASSWORD：Neo4j 密码（与 graph.shared.env 中的 URI/用户配套）。
NEO4J_PASSWORD=
FASTQA_NEO4J_PASSWORD=
