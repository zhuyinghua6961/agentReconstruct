# Local overrides for fastQA
# Copy to config.env when needed.

APP_PORT=8009
FASTQA_TRUST_GATEWAY_ROUTE=1
FASTQA_ENABLE_FILE_CONTEXT_FALLBACK=0
FASTQA_GRAPH_KB_TIMEOUT_MS=3000
FASTQA_GRAPH_KB_MAX_ROWS=20
FASTQA_GRAPH_KB_QUERY_LOGGING=0
FASTQA_GRAPH_DIRECT_ANSWER_MIN_CONFIDENCE=0.8
FASTQA_GRAPH_MAX_DOI_CANDIDATES=20
FASTQA_GRAPH_ALLOW_SUSPICIOUS_DOI_FOR_RAG=0
