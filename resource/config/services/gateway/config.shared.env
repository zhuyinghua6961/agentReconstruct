# 中文: GATEWAY_GUNICORN_WORKERS：网关服务：并发 worker 或线程配置。
GATEWAY_GUNICORN_WORKERS=8
# 中文: GATEWAY_REFRESH_SURVIVABLE_QA_TASKS_ENABLED：网关服务：功能开关，使用 1/0、true/false 控制。
GATEWAY_REFRESH_SURVIVABLE_QA_TASKS_ENABLED=1
# 中文: INTERACTIVE_EXECUTION_MAX_CONCURRENT：数量、容量或并发限制。
INTERACTIVE_EXECUTION_MAX_CONCURRENT=50
# 中文: INTERACTIVE_EXECUTION_FAST_OR_PATENT_MAX_CONCURRENT：数量、容量或并发限制。
INTERACTIVE_EXECUTION_FAST_OR_PATENT_MAX_CONCURRENT=50
# 中文: INTERACTIVE_EXECUTION_THINKING_MAX_CONCURRENT：数量、容量或并发限制。
INTERACTIVE_EXECUTION_THINKING_MAX_CONCURRENT=20
# 中文: INTERACTIVE_EXECUTION_PER_USER_MAX_ACTIVE：数量、容量或并发限制。
INTERACTIVE_EXECUTION_PER_USER_MAX_ACTIVE=5
# 中文: INTERACTIVE_EXECUTION_THINKING_MIN_SLOTS：数量、容量或并发限制。
INTERACTIVE_EXECUTION_THINKING_MIN_SLOTS=1
# 中文: INTERACTIVE_QUEUE_MAX_SIZE：数量、容量或并发限制。
INTERACTIVE_QUEUE_MAX_SIZE=200
# 中文: INTERACTIVE_QUEUED_TTL_SECONDS：缓存或凭证有效期。
INTERACTIVE_QUEUED_TTL_SECONDS=900
# 中文: INTERACTIVE_POST_ADMIT_ATTACH_TTL_SECONDS：缓存或凭证有效期。
INTERACTIVE_POST_ADMIT_ATTACH_TTL_SECONDS=600
# 中文: GATEWAY_ADMISSION_POLL_INTERVAL_SECONDS：网关服务：轮询或同步间隔。
GATEWAY_ADMISSION_POLL_INTERVAL_SECONDS=5
# 中文: REDIS_KEY_PREFIX：Redis 缓存：运行模式、命名或路由标识。
REDIS_KEY_PREFIX=gateway
