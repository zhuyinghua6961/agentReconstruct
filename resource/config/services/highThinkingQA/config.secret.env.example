# ============================================================================
# Secret runtime config template (DO NOT commit filled values)
# ============================================================================
# Copy to config.secret.env and fill private credentials.
# ============================================================================

# Model credentials
# 中文: LLM_API_KEY：大模型：敏感凭据，填写真实密钥、令牌或密码。
LLM_API_KEY=
# 中文: LLM_IS_THINKING_MODEL：大模型：当前模型是否支持 thinking 参数，默认 false。
LLM_IS_THINKING_MODEL=false
# 中文: LLM_THINKING_ENABLED：大模型：仅最终答案阶段是否允许开启 thinking，默认 false。
LLM_THINKING_ENABLED=false
# 中文: HIGHTHINKINGQA_EMBEDDING_API_KEY：深度问答服务：敏感凭据，填写真实密钥、令牌或密码。
HIGHTHINKINGQA_EMBEDDING_API_KEY=

# Auth
# 中文: JWT_SECRET：JWT 认证：敏感凭据，填写真实密钥、令牌或密码。
JWT_SECRET=
