# Deprecated single-file compatibility template.
# Preferred setup: keep defaults in config.shared.env and local secrets in config.secret.env.

# LLM
# 中文: LLM_MODEL：大模型：模型名称。
LLM_MODEL=qwen3-max

# Embedding
# 中文: HIGHTHINKINGQA_EMBEDDING_BASE_URL：深度问答服务：Embedding 接口地址。
HIGHTHINKINGQA_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 中文: HIGHTHINKINGQA_EMBEDDING_MODEL：深度问答服务：Embedding 模型名称。
HIGHTHINKINGQA_EMBEDDING_MODEL=text-embedding-v4
# 中文: HIGHTHINKINGQA_EMBEDDING_DIMENSIONS：深度问答服务：Embedding 向量维度。
HIGHTHINKINGQA_EMBEDDING_DIMENSIONS=2048

# Runtime
# 中文: APP_PORT：服务监听或依赖连接端口。
APP_PORT=8008
# 中文: APP_LOG_LEVEL：应用日志级别，例如 INFO、DEBUG、WARNING。
APP_LOG_LEVEL=INFO
# 中文: CORS_ORIGINS：跨域访问：允许访问的前端来源列表。
CORS_ORIGINS=*
# 中文: GUNICORN_WORKER_CLASS：并发 worker 或线程配置。
GUNICORN_WORKER_CLASS=uvicorn.workers.UvicornWorker
# 中文: GUNICORN_WORKERS：并发 worker 或线程配置。
GUNICORN_WORKERS=2
# 中文: GUNICORN_THREADS：并发 worker 或线程配置。
GUNICORN_THREADS=8
# 中文: GUNICORN_TIMEOUT：超时时间配置。
GUNICORN_TIMEOUT=1800

# Auth
# 中文: JWT_SECRET：JWT 认证：敏感凭据，填写真实密钥、令牌或密码。
JWT_SECRET=change_me_for_production
