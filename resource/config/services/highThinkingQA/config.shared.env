# ============================================================================
# Public runtime config (safe to commit)
# ============================================================================
# Commit this file. Keep credentials in config.secret.env or explicit env vars.
# Service-config load order: config.env -> config.shared.env -> config.secret.env -> .env
# ============================================================================

# LLM / embedding defaults
# 中文: LLM_MODEL：大模型：模型名称。
LLM_MODEL=qwen3-max
# 中文: HIGHTHINKINGQA_EMBEDDING_BASE_URL：深度问答服务：服务或接口访问地址。
HIGHTHINKINGQA_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 中文: HIGHTHINKINGQA_EMBEDDING_MODEL：深度问答服务：模型名称。
HIGHTHINKINGQA_EMBEDDING_MODEL=text-embedding-v4
# 中文: HIGHTHINKINGQA_EMBEDDING_DIMENSIONS：深度问答服务：数量、容量或并发限制。
HIGHTHINKINGQA_EMBEDDING_DIMENSIONS=2048

# Chunking / retrieval
# 中文: MAX_CHUNK_TOKENS：敏感凭据，填写真实密钥、令牌或密码。
MAX_CHUNK_TOKENS=4000
# 中文: SEMANTIC_CHUNK_MIN_TOKENS：敏感凭据，填写真实密钥、令牌或密码。
SEMANTIC_CHUNK_MIN_TOKENS=2000
# 中文: SEMANTIC_CHUNK_MAX_TOKENS：敏感凭据，填写真实密钥、令牌或密码。
SEMANTIC_CHUNK_MAX_TOKENS=4000
# 中文: TIKTOKEN_ENCODING：用于估算 token 数的 tiktoken 编码名称。
TIKTOKEN_ENCODING=cl100k_base
# 中文: RETRIEVAL_TOP_K：数量、容量或并发限制。
RETRIEVAL_TOP_K=3
# 中文: RETRIEVAL_PIPELINE_BATCH_SIZE：数量、容量或并发限制。
RETRIEVAL_PIPELINE_BATCH_SIZE=2
# 中文: NUM_SUB_QUESTIONS：深度问答拆解阶段生成的子问题数量。
NUM_SUB_QUESTIONS=5
# 中文: MAX_CHECK_LOOPS：深度问答检查/修订循环的最大轮数。
MAX_CHECK_LOOPS=2
# Log DOI provenance per ask (R=retrieved chunks, P=pre-answers, F=answer): search logs for DOI_TRACE
# 中文: HIGHTHINKINGQA_DOI_DIAGNOSTICS：是否输出 highThinkingQA DOI 诊断信息。
HIGHTHINKINGQA_DOI_DIAGNOSTICS=1

# Embedding ingestion concurrency
# 中文: HIGHTHINKINGQA_EMBEDDING_BATCH_SIZE：深度问答服务：数量、容量或并发限制。
HIGHTHINKINGQA_EMBEDDING_BATCH_SIZE=10
# 中文: HIGHTHINKINGQA_EMBEDDING_API_RPM：深度问答服务：数量、容量或并发限制。
HIGHTHINKINGQA_EMBEDDING_API_RPM=1800
# 中文: HIGHTHINKINGQA_EMBEDDING_API_TPM：深度问答服务：数量、容量或并发限制。
HIGHTHINKINGQA_EMBEDDING_API_TPM=1200000
# 中文: HIGHTHINKINGQA_EMBEDDING_CONCURRENCY：深度问答服务：数量、容量或并发限制。
HIGHTHINKINGQA_EMBEDDING_CONCURRENCY=2
# 中文: HIGHTHINKINGQA_EMBEDDING_MAX_CONCURRENT_REQUESTS：深度问答服务：数量、容量或并发限制。
HIGHTHINKINGQA_EMBEDDING_MAX_CONCURRENT_REQUESTS=4
# 中文: HIGHTHINKINGQA_EMBEDDING_MAX_INPUT_TOKENS：深度问答服务：敏感凭据，填写真实密钥、令牌或密码。
HIGHTHINKINGQA_EMBEDDING_MAX_INPUT_TOKENS=8000
# 中文: HIGHTHINKINGQA_EMBEDDING_MAX_RETRIES：深度问答服务：失败重试次数或重试间隔。
HIGHTHINKINGQA_EMBEDDING_MAX_RETRIES=5
# 中文: HIGHTHINKINGQA_EMBEDDING_QUEUE_SIZE：深度问答服务：数量、容量或并发限制。
HIGHTHINKINGQA_EMBEDDING_QUEUE_SIZE=200

# Local paths
# 中文: PAPERS_DIR：本地目录、文件或资源根路径。
PAPERS_DIR=../../../highThinkingQA/papers
# 中文: PROMPTS_DIR：本地目录、文件或资源根路径。
PROMPTS_DIR=prompts
# 中文: CHROMA_PERSIST_DIR：向量库：本地目录、文件或资源根路径。
CHROMA_PERSIST_DIR=../../../highThinkingQA/vectordb
# 中文: CHROMA_COLLECTION_NAME：向量库：运行模式、命名或路由标识。
CHROMA_COLLECTION_NAME=lfp_papers
# 中文: UPLOAD_DIR：文件上传：本地目录、文件或资源根路径。
UPLOAD_DIR=uploads
# 中文: CHAT_JSON_BASE_DIR：对话存储：本地目录、文件或资源根路径。
CHAT_JSON_BASE_DIR=data/conversations
# 中文: CHAT_JSON_STORAGE_PREFIX：对话存储：对象存储桶、区域或对象路径配置。
CHAT_JSON_STORAGE_PREFIX=conversations

# HTTP runtime defaults
# 中文: APP_ENV：运行模式、命名或路由标识。
APP_ENV=dev
# 中文: APP_LOG_LEVEL：应用日志级别，例如 INFO、DEBUG、WARNING。
APP_LOG_LEVEL=INFO
# 中文: BACKEND_SERVER：后端运行方式标识，例如 gunicorn。
BACKEND_SERVER=gunicorn
# 中文: GUNICORN_WORKER_CLASS：并发 worker 或线程配置。
GUNICORN_WORKER_CLASS=uvicorn.workers.UvicornWorker
# 中文: GUNICORN_WORKERS：并发 worker 或线程配置。
GUNICORN_WORKERS=8
# 中文: GUNICORN_THREADS：并发 worker 或线程配置。
GUNICORN_THREADS=8
# 中文: GUNICORN_TIMEOUT：超时时间配置。
GUNICORN_TIMEOUT=1800
# 中文: GUNICORN_KEEPALIVE：通用配置项。
GUNICORN_KEEPALIVE=15
# 中文: GUNICORN_MAX_REQUESTS：数量、容量或并发限制。
GUNICORN_MAX_REQUESTS=1000
# 中文: GUNICORN_MAX_REQUESTS_JITTER：数量、容量或并发限制。
GUNICORN_MAX_REQUESTS_JITTER=100
# 中文: ENABLE_CORS：跨域访问：功能开关，使用 1/0、true/false 控制。
ENABLE_CORS=1
# 中文: CORS_ORIGINS：跨域访问：允许访问的前端来源列表。
CORS_ORIGINS=*
# 中文: ASK_STREAM_MAX_CONCURRENT：数量、容量或并发限制。
ASK_STREAM_MAX_CONCURRENT=20
# 中文: ASK_EXECUTOR_MAX_WORKERS：并发 worker 或线程配置。
ASK_EXECUTOR_MAX_WORKERS=20
# 中文: ASK_TIMEOUT_SECONDS：超时时间配置。
ASK_TIMEOUT_SECONDS=1800
# 中文: SSE_HEARTBEAT_SECONDS：通用配置项。
SSE_HEARTBEAT_SECONDS=15
# 中文: CHAT_PERSIST_ASYNC_WORKERS：对话存储：并发 worker 或线程配置。
CHAT_PERSIST_ASYNC_WORKERS=4
# 中文: CONVERSATION_EXECUTION_AUTHORITY_TARGET：对话执行权限校验目标服务。
CONVERSATION_EXECUTION_AUTHORITY_TARGET=public_service
# 中文: CONVERSATION_ASSISTANT_WRITE_TARGET：助手消息写入目标服务。
CONVERSATION_ASSISTANT_WRITE_TARGET=public_service

# Auth / storage / persistence defaults
# 中文: JWT_EXPIRE_SECONDS：JWT 认证：缓存或凭证有效期。
JWT_EXPIRE_SECONDS=86400
# 中文: PASSWORD_EXPIRE_DAYS：用户密码过期天数。
PASSWORD_EXPIRE_DAYS=180
# 中文: LOGIN_FAILURE_LOCK_THRESHOLD：触发登录失败锁定的连续失败次数。
LOGIN_FAILURE_LOCK_THRESHOLD=5
# 中文: LOGIN_FAILURE_LOCK_MINUTES：登录失败锁定持续时间，单位分钟。
LOGIN_FAILURE_LOCK_MINUTES=5
# 中文: MAX_PDF_PAGES：数量、容量或并发限制。
MAX_PDF_PAGES=50
# Redis defaults
# 中文: REDIS_KEY_PREFIX：Redis 缓存：运行模式、命名或路由标识。
REDIS_KEY_PREFIX=highthinkingqa
# 中文: HT_QA_CACHE_EPOCH：highThinkingQA 缓存版本号，调整后可整体失效旧缓存。
HT_QA_CACHE_EPOCH=0
# 中文: HT_QA_DIRECT_CACHE_TTL_SECONDS：深度问答服务：缓存或凭证有效期。
HT_QA_DIRECT_CACHE_TTL_SECONDS=43200
# 中文: HT_QA_DECOMPOSE_CACHE_TTL_SECONDS：深度问答服务：缓存或凭证有效期。
HT_QA_DECOMPOSE_CACHE_TTL_SECONDS=43200
# 中文: HT_QA_RETRIEVE_CACHE_TTL_SECONDS：深度问答服务：缓存或凭证有效期。
HT_QA_RETRIEVE_CACHE_TTL_SECONDS=43200
# 中文: HT_QA_CACHE_LOCK_ENABLED：深度问答服务：功能开关，使用 1/0、true/false 控制。
HT_QA_CACHE_LOCK_ENABLED=1
# 中文: HT_QA_CACHE_WAIT_MS：深度问答服务：通用配置项。
HT_QA_CACHE_WAIT_MS=400
# 中文: HT_QA_CACHE_LOCK_TTL_SECONDS：深度问答服务：缓存或凭证有效期。
HT_QA_CACHE_LOCK_TTL_SECONDS=30
