# Copy to infrastructure.secret.env for local shared secrets.

# 中文: PUBLIC_SERVICE_INTERNAL_AUTH_TOKEN：公共服务：敏感凭据，填写真实密钥、令牌或密码。
PUBLIC_SERVICE_INTERNAL_AUTH_TOKEN=

# 中文: REDIS_PASSWORD：Redis 缓存：敏感凭据，填写真实密钥、令牌或密码。
REDIS_PASSWORD=
# 中文: REDIS_USERNAME：Redis 缓存：访问依赖服务的用户名。
REDIS_USERNAME=
# 中文: REDIS_URL：Redis 缓存：服务或接口访问地址。
REDIS_URL=

# 中文: MYSQL_USER：MySQL 数据库：访问依赖服务的用户名。
MYSQL_USER=
# 中文: MYSQL_PASSWORD：MySQL 数据库：敏感凭据，填写真实密钥、令牌或密码。
MYSQL_PASSWORD=

# 中文: MINIO_ENDPOINT：MinIO 对象存储：服务或接口访问地址。
MINIO_ENDPOINT=
# 中文: MINIO_ACCESS_KEY：MinIO 对象存储：敏感凭据，填写真实密钥、令牌或密码。
MINIO_ACCESS_KEY=
# 中文: MINIO_SECRET_KEY：MinIO 对象存储：敏感凭据，填写真实密钥、令牌或密码。
MINIO_SECRET_KEY=
# 中文: MINIO_REGION：MinIO 对象存储：对象存储桶、区域或对象路径配置。
MINIO_REGION=
