# 中文: HIGHTHINKINGQA_SERVICE_RUNTIME_ROOT：深度问答服务：本地目录、文件或资源根路径。
HIGHTHINKINGQA_SERVICE_RUNTIME_ROOT=/home/cqy/worktrees/highThinking/resource/runtime/dev/highThinkingQA
# 中文: HIGHTHINKINGQA_SERVICE_ASSET_ROOT：深度问答服务：本地目录、文件或资源根路径。
HIGHTHINKINGQA_SERVICE_ASSET_ROOT=/home/cqy/worktrees/highThinking/resource/assets

# Example: future fastQA
# 中文: FASTQA_SERVICE_CONFIG_ROOT：快速问答服务：本地目录、文件或资源根路径。
FASTQA_SERVICE_CONFIG_ROOT=/home/cqy/worktrees/highThinking/resource/config/services/fastQA
