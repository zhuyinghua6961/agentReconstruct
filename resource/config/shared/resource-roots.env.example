# Shared resource-root contract example

# 中文: RESOURCE_ROOT：统一资源目录根路径。
RESOURCE_ROOT=/home/cqy/worktrees/highThinking/resource

# Example: gateway
# 中文: GATEWAY_SERVICE_CONFIG_ROOT：网关服务：本地目录、文件或资源根路径。
GATEWAY_SERVICE_CONFIG_ROOT=/home/cqy/worktrees/highThinking/resource/config/services/gateway
# 中文: GATEWAY_SERVICE_STATE_ROOT：网关服务：本地目录、文件或资源根路径。
GATEWAY_SERVICE_STATE_ROOT=/home/cqy/worktrees/highThinking/resource/state/dev/gateway
# 中文: GATEWAY_SERVICE_RUNTIME_ROOT：网关服务：本地目录、文件或资源根路径。
GATEWAY_SERVICE_RUNTIME_ROOT=/home/cqy/worktrees/highThinking/resource/runtime/dev/gateway
# 中文: GATEWAY_SERVICE_ASSET_ROOT：网关服务：本地目录、文件或资源根路径。
GATEWAY_SERVICE_ASSET_ROOT=/home/cqy/worktrees/highThinking/resource/assets

# Example: public-service
# 中文: PUBLIC_SERVICE_SERVICE_CONFIG_ROOT：公共服务：本地目录、文件或资源根路径。
PUBLIC_SERVICE_SERVICE_CONFIG_ROOT=/home/cqy/worktrees/highThinking/resource/config/services/public-service
# 中文: PUBLIC_SERVICE_SERVICE_STATE_ROOT：公共服务：本地目录、文件或资源根路径。
PUBLIC_SERVICE_SERVICE_STATE_ROOT=/home/cqy/worktrees/highThinking/resource/state/dev/public-service
# 中文: PUBLIC_SERVICE_SERVICE_RUNTIME_ROOT：公共服务：本地目录、文件或资源根路径。
PUBLIC_SERVICE_SERVICE_RUNTIME_ROOT=/home/cqy/worktrees/highThinking/resource/runtime/dev/public-service
# 中文: PUBLIC_SERVICE_SERVICE_ASSET_ROOT：公共服务：本地目录、文件或资源根路径。
PUBLIC_SERVICE_SERVICE_ASSET_ROOT=/home/cqy/worktrees/highThinking/resource/assets

# Example: future highThinkingQA
