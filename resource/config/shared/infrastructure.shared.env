# Shared backend infrastructure defaults. Service-local env files may override.

# Service ports
# 中文: GATEWAY_HOST：网关服务：服务监听或依赖连接主机。
GATEWAY_HOST=0.0.0.0
# 中文: GATEWAY_PORT：网关服务：服务监听或依赖连接端口。
GATEWAY_PORT=8101
# 中文: PUBLIC_SERVICE_HOST：公共服务：服务监听或依赖连接主机。
PUBLIC_SERVICE_HOST=0.0.0.0
# 中文: PUBLIC_SERVICE_PORT：公共服务：服务监听或依赖连接端口。
PUBLIC_SERVICE_PORT=8102
# 中文: FASTQA_HOST：快速问答服务：服务监听或依赖连接主机。
FASTQA_HOST=0.0.0.0
# 中文: FASTQA_PORT：快速问答服务：服务监听或依赖连接端口。
FASTQA_PORT=8008
# 中文: FASTQA_FASTAPI_PORT：快速问答服务：服务监听或依赖连接端口。
FASTQA_FASTAPI_PORT=8008
# 中文: HIGHTHINKINGQA_HOST：深度问答服务：服务监听或依赖连接主机。
HIGHTHINKINGQA_HOST=0.0.0.0
# 中文: HIGHTHINKINGQA_PORT：深度问答服务：服务监听或依赖连接端口。
HIGHTHINKINGQA_PORT=8009
# 中文: PATENT_HOST：专利服务：服务监听或依赖连接主机。
PATENT_HOST=0.0.0.0
# 中文: PATENT_PORT：专利服务：服务监听或依赖连接端口。
PATENT_PORT=8010

# Gateway backend targets
# 中文: PUBLIC_BACKEND_BASE_URL：服务或接口访问地址。
PUBLIC_BACKEND_BASE_URL=http://127.0.0.1:8102
# 中文: FAST_BACKEND_BASE_URL：服务或接口访问地址。
FAST_BACKEND_BASE_URL=http://127.0.0.1:8008
# 中文: THINKING_BACKEND_BASE_URL：服务或接口访问地址。
THINKING_BACKEND_BASE_URL=http://127.0.0.1:8009
# 中文: PATENT_BACKEND_BASE_URL：专利服务：服务或接口访问地址。
PATENT_BACKEND_BASE_URL=http://127.0.0.1:8010

# 中文: REDIS_HOST：Redis 缓存：服务监听或依赖连接主机。
REDIS_HOST=127.0.0.1
# 中文: REDIS_PORT：Redis 缓存：服务监听或依赖连接端口。
REDIS_PORT=6379
# 中文: REDIS_DB：Redis 缓存：数据库名称或数据库编号。
REDIS_DB=0
# 中文: REDIS_SOCKET_CONNECT_TIMEOUT_SEC：Redis 缓存：超时时间配置。
REDIS_SOCKET_CONNECT_TIMEOUT_SEC=2
# 中文: REDIS_SOCKET_TIMEOUT_SEC：Redis 缓存：超时时间配置。
REDIS_SOCKET_TIMEOUT_SEC=2

# 中文: MYSQL_HOST：MySQL 数据库：服务监听或依赖连接主机。
MYSQL_HOST=127.0.0.1
# 中文: MYSQL_PORT：MySQL 数据库：服务监听或依赖连接端口。
MYSQL_PORT=3306
# 中文: MYSQL_DATABASE：MySQL 数据库：数据库名称或数据库编号。
MYSQL_DATABASE=agentcode
# 中文: MYSQL_CONNECT_TIMEOUT_SECONDS：MySQL 数据库：超时时间配置。
MYSQL_CONNECT_TIMEOUT_SECONDS=5
# 中文: MYSQL_READ_TIMEOUT_SECONDS：MySQL 数据库：超时时间配置。
MYSQL_READ_TIMEOUT_SECONDS=30
# 中文: MYSQL_WRITE_TIMEOUT_SECONDS：MySQL 数据库：超时时间配置。
MYSQL_WRITE_TIMEOUT_SECONDS=30
# 中文: MYSQL_CONNECT_RETRIES：MySQL 数据库：失败重试次数或重试间隔。
MYSQL_CONNECT_RETRIES=2
# 中文: MYSQL_CONNECT_RETRY_DELAY_SECONDS：MySQL 数据库：失败重试次数或重试间隔。
MYSQL_CONNECT_RETRY_DELAY_SECONDS=0.15
# 中文: MYSQL_QUERY_RETRIES：MySQL 数据库：失败重试次数或重试间隔。
MYSQL_QUERY_RETRIES=2
# 中文: MYSQL_QUERY_RETRY_DELAY_SECONDS：MySQL 数据库：失败重试次数或重试间隔。
MYSQL_QUERY_RETRY_DELAY_SECONDS=0.05

# 中文: MINIO_BUCKET：MinIO 对象存储：对象存储桶、区域或对象路径配置。
MINIO_BUCKET=agentcode
# 中文: MINIO_SECURE：MinIO 对象存储：功能开关，使用 1/0、true/false 控制。
MINIO_SECURE=0
# 中文: MINIO_REGION：MinIO 对象存储：对象存储桶、区域或对象路径配置。
MINIO_REGION=us-east-1
# 中文: MINIO_DOWNLOAD_EXPIRES：MinIO 对象存储：缓存或凭证有效期。
MINIO_DOWNLOAD_EXPIRES=3600
