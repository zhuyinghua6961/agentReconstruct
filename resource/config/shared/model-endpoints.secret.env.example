# 中文: LLM_API_KEY：大模型：敏感凭据，填写真实密钥、令牌或密码。
LLM_API_KEY=
# 中文: LLM_IS_THINKING_MODEL：大模型：当前模型是否支持 thinking 参数，默认 false。
LLM_IS_THINKING_MODEL=false
# 中文: LLM_THINKING_ENABLED：大模型：仅最终答案阶段是否允许开启 thinking，默认 false。
LLM_THINKING_ENABLED=false
# 中文: INTENT_MODEL_API_KEY：轻量意图模型：敏感凭据；为空时 fastQA/patentQA 复用主 LLM client。
INTENT_MODEL_API_KEY=
# 中文: EMBEDDING_API_KEY：向量嵌入：敏感凭据，填写真实密钥、令牌或密码。
EMBEDDING_API_KEY=
# 中文: RERANK_API_KEY：重排模型：敏感凭据，填写真实密钥、令牌或密码。
RERANK_API_KEY=
