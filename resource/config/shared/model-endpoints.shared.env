# Shared model endpoint defaults. Service-local env files may override.

# 中文: LLM_BASE_URL：大模型：服务或接口访问地址。
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 中文: LLM_MODEL：大模型：模型名称。
LLM_MODEL=deepseek-v4-pro
# 中文: LLM_IS_THINKING_MODEL：大模型：当前模型是否支持 thinking 参数，默认关闭。
LLM_IS_THINKING_MODEL=true
# 中文: LLM_THINKING_ENABLED：大模型：仅最终答案阶段是否允许开启 thinking，默认关闭。
LLM_THINKING_ENABLED=true
# 中文: LLM_CONNECT_TIMEOUT_SECONDS：大模型：超时时间配置。
LLM_CONNECT_TIMEOUT_SECONDS=15
# 中文: LLM_READ_TIMEOUT_SECONDS：大模型：超时时间配置。
LLM_READ_TIMEOUT_SECONDS=180
# 中文: LLM_STREAM_READ_TIMEOUT_SECONDS：大模型：超时时间配置。
LLM_STREAM_READ_TIMEOUT_SECONDS=600
# 中文: LLM_WRITE_TIMEOUT_SECONDS：大模型：超时时间配置。
LLM_WRITE_TIMEOUT_SECONDS=180
# 中文: LLM_POOL_TIMEOUT_SECONDS：大模型：超时时间配置。
LLM_POOL_TIMEOUT_SECONDS=30
# 中文: LLM_KEEPALIVE_EXPIRY_SECONDS：大模型 HTTP 连接池空闲连接保活时间，单位秒。
LLM_KEEPALIVE_EXPIRY_SECONDS=120
# 中文: LLM_MAX_CONNECTIONS：大模型：数量、容量或并发限制。
LLM_MAX_CONNECTIONS=160
# 中文: LLM_MAX_KEEPALIVE_CONNECTIONS：大模型：数量、容量或并发限制。
LLM_MAX_KEEPALIVE_CONNECTIONS=64

# 中文: INTENT_MODEL_ENABLED：轻量意图模型：设为 1/true 时在 fastQA/patentQA Stage1 前启用意图快筛。
INTENT_MODEL_ENABLED=true
# 中文: INTENT_MODEL_BASE_URL：轻量意图模型：OpenAI-compatible 服务或接口访问地址。
INTENT_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 中文: INTENT_MODEL：轻量意图模型：chat.completions 模型名称。
INTENT_MODEL=qwen3-8b
# 中文: INTENT_MODEL_TIMEOUT_SECONDS：轻量意图模型：单次非流式请求超时时间。
INTENT_MODEL_TIMEOUT_SECONDS=30

# 中文: EMBEDDING_BASE_URL：向量嵌入：服务或接口访问地址。
EMBEDDING_BASE_URL=http://127.0.0.1:8001/v1/embeddings
# 中文: EMBEDDING_MODEL：向量嵌入：模型名称。
EMBEDDING_MODEL=bge-local
# 中文: EMBEDDING_MODEL_TYPE：向量嵌入：模型加载或调用类型。
EMBEDDING_MODEL_TYPE=remote
# 中文: EMBEDDING_API_URL：向量嵌入：服务或接口访问地址。
EMBEDDING_API_URL=http://127.0.0.1:8001/v1/embeddings
# 中文: EMBEDDING_API_MODEL：向量嵌入：模型名称。
EMBEDDING_API_MODEL=bge-local
# 中文: EMBEDDING_API_TIMEOUT_SECONDS：向量嵌入：超时时间配置。
EMBEDDING_API_TIMEOUT_SECONDS=120

# 中文: RERANK_PROVIDER：重排模型：服务提供方类型。
RERANK_PROVIDER=local
# 中文: RERANK_BASE_URL：重排模型：服务或接口访问地址。
RERANK_BASE_URL=http://localhost:8084
# 中文: RERANK_MODEL：重排模型：模型名称。
RERANK_MODEL=qwen3-vl-rerank
# 中文: RERANK_TIMEOUT_SECONDS：重排模型：超时时间配置。
RERANK_TIMEOUT_SECONDS=20
