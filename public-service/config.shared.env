# ============================================================================
# Public Service runtime config (safe to commit)
# ============================================================================
# Usage:
# PUBLIC_SERVICE_ENV_FILES=/home/cqy/worktrees/highThinking/public-service/config.shared.env:/home/cqy/worktrees/highThinking/public-service/config.secret.env \
#   conda run --no-capture-output -n agent gunicorn -k uvicorn.workers.UvicornWorker app.main:app --chdir /home/cqy/worktrees/highThinking/public-service/backend --bind 0.0.0.0:8102 --workers 8 --timeout 600
# ============================================================================

# App
APP_ENV=development
PUBLIC_SERVICE_APP_NAME=agentCode Public Service
PUBLIC_SERVICE_DEBUG=0
PUBLIC_SERVICE_HOST=0.0.0.0
PUBLIC_SERVICE_PORT=8102
PUBLIC_SERVICE_API_PREFIX=/api
PUBLIC_SERVICE_DOCS_URL=/docs
PUBLIC_SERVICE_OPENAPI_URL=/openapi.json
PUBLIC_SERVICE_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5174,http://localhost:5174

# Data roots
PUBLIC_SERVICE_DATA_ROOT=/home/cqy/worktrees/highThinking/public-service/data/runtime
UPLOAD_DIR=uploads
PAPERS_DIR=papers
CHAT_JSON_BASE_DIR=data/conversations
VECTOR_DB_PATH=vector_database
VECTOR_COLLECTION_NAME=lfp_papers
TRANSLATION_CACHE_DIR=translation_cache
TRANSLATION_CACHE_OBJECT_NAME=translation_cache/translations.json
TRANSLATION_CACHE_MAX_ENTRIES=10000
TRANSLATION_CACHE_REMOTE_SYNC_INTERVAL_SECONDS=5
PUBLIC_SERVICE_LOGS_DIR=logs
LOCAL_STORAGE_ROOT=storage
PUBLIC_SERVICE_ENABLE_LEGACY_CONVERSATION_FALLBACK=0

# Auth
JWT_EXPIRE_SECONDS=86400
PASSWORD_EXPIRE_DAYS=180
LOGIN_FAILURE_LOCK_THRESHOLD=5
LOGIN_FAILURE_LOCK_MINUTES=5

# MySQL / Redis runtime
REDIS_ENABLED=1
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_KEY_PREFIX=public_service
REDIS_SOCKET_CONNECT_TIMEOUT_SEC=2
REDIS_SOCKET_TIMEOUT_SEC=2

# Cache / quota
QUOTA_CACHE_EPOCH=0
QUOTA_CONFIG_CACHE_TTL_SECONDS=600
QUOTA_ACTIVE_LIST_CACHE_TTL_SECONDS=300
QUOTA_ALL_LIST_CACHE_TTL_SECONDS=300
QUOTA_OVERRIDE_CACHE_TTL_SECONDS=600
CONVERSATION_LIST_CACHE_TTL_SECONDS=60
CONVERSATION_DETAIL_CACHE_TTL_SECONDS=30
CONVERSATION_DETAIL_CACHE_TOUCH_ON_HIT=1
CONVERSATION_LIST_RECENT_PAGES_TTL_SECONDS=900
CONVERSATION_LIST_RECENT_PAGES_LIMIT=8
QUOTA_LOCK_TTL_SECONDS=30
QUOTA_LOCK_WAIT_SECONDS=10
QUOTA_LOCK_RETRY_INTERVAL_MS=100

# Upload / outbox / storage behavior
UPLOAD_FILE_PROCESSING_ENABLED=1
UPLOAD_PROCESSING_WORKER_MAX_WORKERS=2
UPLOAD_PROCESSING_MAX_PDF_PAGES=20
UPLOAD_PROCESSING_POLL_INTERVAL_MS=1000
UPLOAD_PROCESSING_RECOVERY_SCAN_LIMIT=500
OUTBOX_WORKER_BATCH_SIZE=100
OUTBOX_WORKER_POLL_INTERVAL_MS=1000
OUTBOX_MAX_ATTEMPTS=20
OUTBOX_RETRY_BASE_SECONDS=2
OUTBOX_RETRY_MAX_SECONDS=300
OUTBOX_PROCESSING_TIMEOUT_SECONDS=120
DELETED_FILE_CLEANUP_RECONCILE_LIMIT=3
CONVERSATION_LOCK_TTL_SECONDS=30
CONVERSATION_LOCK_WAIT_SECONDS=10
CONVERSATION_LOCK_RETRY_INTERVAL_MS=100
MINIO_USE_PROXY=1
MINIO_DOWNLOAD_EXPIRES=3600

# Documents / translation / retrieval
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MAX_PDF_PAGES=50
REFERENCE_PREVIEW_MAX_WORKERS=4
NEO4J_USERNAME=neo4j
