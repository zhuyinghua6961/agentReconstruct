# ============================================================================
# Public Service single-file example
# ============================================================================
# Alternative startup:
# PUBLIC_SERVICE_ENV_FILE=/home/cqy/worktrees/highThinking/public-service/config.env \
#   conda run --no-capture-output -n agent gunicorn -k uvicorn.workers.UvicornWorker app.main:app --chdir /home/cqy/worktrees/highThinking/public-service/backend --bind 0.0.0.0:8102 --workers 1 --timeout 600
# ============================================================================

# 中文: APP_ENV：运行模式、命名或路由标识。
APP_ENV=development
# 中文: PUBLIC_SERVICE_APP_NAME：公共服务：运行模式、命名或路由标识。
PUBLIC_SERVICE_APP_NAME=agentCode Public Service
# 中文: PUBLIC_SERVICE_DEBUG：公共服务：功能开关，使用 1/0、true/false 控制。
PUBLIC_SERVICE_DEBUG=0
# 中文: PUBLIC_SERVICE_HOST：公共服务：服务监听或依赖连接主机。
PUBLIC_SERVICE_HOST=0.0.0.0
# 中文: PUBLIC_SERVICE_PORT：公共服务：服务监听或依赖连接端口。
PUBLIC_SERVICE_PORT=8102
# 中文: PUBLIC_SERVICE_API_PREFIX：公共服务：运行模式、命名或路由标识。
PUBLIC_SERVICE_API_PREFIX=/api
# 中文: PUBLIC_SERVICE_DOCS_URL：公共服务：服务或接口访问地址。
PUBLIC_SERVICE_DOCS_URL=/docs
# 中文: PUBLIC_SERVICE_OPENAPI_URL：公共服务：服务或接口访问地址。
PUBLIC_SERVICE_OPENAPI_URL=/openapi.json
# 中文: PUBLIC_SERVICE_CORS_ORIGINS：跨域访问：允许访问的前端来源列表。
PUBLIC_SERVICE_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5174,http://localhost:5174

# 中文: PUBLIC_SERVICE_DATA_ROOT：公共服务：本地目录、文件或资源根路径。
PUBLIC_SERVICE_DATA_ROOT=../data/runtime
# 中文: UPLOAD_DIR：文件上传：本地目录、文件或资源根路径。
UPLOAD_DIR=uploads
# 中文: PAPERS_DIR：本地目录、文件或资源根路径。
PAPERS_DIR=papers
# 中文: CHAT_JSON_BASE_DIR：对话存储：本地目录、文件或资源根路径。
CHAT_JSON_BASE_DIR=data/conversations
# 中文: VECTOR_DB_PATH：向量库：本地目录、文件或资源根路径。
VECTOR_DB_PATH=vector_database
# 中文: VECTOR_COLLECTION_NAME：向量库：运行模式、命名或路由标识。
VECTOR_COLLECTION_NAME=lfp_papers
# 中文: TRANSLATION_CACHE_DIR：本地目录、文件或资源根路径。
TRANSLATION_CACHE_DIR=translation_cache
# 中文: TRANSLATION_CACHE_OBJECT_NAME：对象存储桶、区域或对象路径配置。
TRANSLATION_CACHE_OBJECT_NAME=translation_cache/translations.json
# 中文: TRANSLATION_CACHE_MAX_ENTRIES：数量、容量或并发限制。
TRANSLATION_CACHE_MAX_ENTRIES=10000
# 中文: TRANSLATION_CACHE_REMOTE_SYNC_INTERVAL_SECONDS：轮询或同步间隔。
TRANSLATION_CACHE_REMOTE_SYNC_INTERVAL_SECONDS=5
# 中文: PUBLIC_SERVICE_LOGS_DIR：公共服务：本地目录、文件或资源根路径。
PUBLIC_SERVICE_LOGS_DIR=logs
# 中文: LOCAL_STORAGE_ROOT：公共服务本地文件存储根目录。
LOCAL_STORAGE_ROOT=storage
# 中文: PUBLIC_SERVICE_ENABLE_LEGACY_CONVERSATION_FALLBACK：公共服务是否允许旧版对话存储兜底读取。
PUBLIC_SERVICE_ENABLE_LEGACY_CONVERSATION_FALLBACK=0

# 中文: JWT_EXPIRE_SECONDS：JWT 认证：缓存或凭证有效期。
JWT_EXPIRE_SECONDS=86400
# 中文: PASSWORD_EXPIRE_DAYS：用户密码过期天数。
PASSWORD_EXPIRE_DAYS=180
# 中文: LOGIN_FAILURE_LOCK_THRESHOLD：触发登录失败锁定的连续失败次数。
LOGIN_FAILURE_LOCK_THRESHOLD=5
# 中文: LOGIN_FAILURE_LOCK_MINUTES：登录失败锁定持续时间，单位分钟。
LOGIN_FAILURE_LOCK_MINUTES=5
# 中文: JWT_SECRET：JWT 认证：敏感凭据，填写真实密钥、令牌或密码。
JWT_SECRET=replace-with-strong-secret

# 中文: REDIS_KEY_PREFIX：Redis 缓存：运行模式、命名或路由标识。
REDIS_KEY_PREFIX=public_service

# 中文: LLM_API_KEY：大模型：敏感凭据，填写真实密钥、令牌或密码。
LLM_API_KEY=replace-with-model-api-key
# 中文: LLM_BASE_URL：大模型：服务或接口访问地址。
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 中文: LLM_MODEL：大模型：模型名称。
LLM_MODEL=deepseek-v3.1
# 中文: LLM_IS_THINKING_MODEL：大模型：当前模型是否支持 thinking 参数，默认 false。
LLM_IS_THINKING_MODEL=false
# 中文: LLM_THINKING_ENABLED：大模型：仅最终答案阶段是否允许开启 thinking，默认 false。
LLM_THINKING_ENABLED=false
# 中文: MAX_PDF_PAGES：数量、容量或并发限制。
MAX_PDF_PAGES=50
# 中文: TRANSLATION_CHUNK_CHARS：全文翻译打包目标 chunk 字符数。
TRANSLATION_CHUNK_CHARS=3500
# 中文: TRANSLATION_CHUNK_HARD_MAX：单 chunk 硬上限，超出后按段落边界二次切分。
TRANSLATION_CHUNK_HARD_MAX=4500
# 中文: TRANSLATION_PROMPT_VERSION：翻译 prompt 版本号，变更后可使旧缓存失效。
TRANSLATION_PROMPT_VERSION=2
# 中文: TRANSLATION_CACHE_EPOCH：翻译 Redis 缓存版本号，调整后可整体失效旧缓存。
TRANSLATION_CACHE_EPOCH=0
# 中文: TRANSLATION_REDIS_CACHE_ENABLED：是否启用翻译 Redis 缓存。
TRANSLATION_REDIS_CACHE_ENABLED=1
# 中文: TRANSLATION_REDIS_CHUNK_TTL_SECONDS：翻译 chunk 级 Redis 缓存 TTL（秒）。
TRANSLATION_REDIS_CHUNK_TTL_SECONDS=604800
# 中文: TRANSLATION_REDIS_DOCUMENT_TTL_SECONDS：全文翻译整篇 Redis 缓存 TTL（秒）。
TRANSLATION_REDIS_DOCUMENT_TTL_SECONDS=604800
# 中文: TRANSLATION_DOCUMENT_LOCK_TTL_SECONDS：全文翻译并发锁 TTL（秒）。
TRANSLATION_DOCUMENT_LOCK_TTL_SECONDS=1800
# 中文: TRANSLATION_DOCUMENT_LOCK_WAIT_SECONDS：等待其他 worker 完成全文翻译的最长秒数。
TRANSLATION_DOCUMENT_LOCK_WAIT_SECONDS=30
# 中文: SUMMARIZE_MAX_INPUT_CHARS：PDF 总结送入模型的最大正文字符数。
SUMMARIZE_MAX_INPUT_CHARS=50000
# 中文: REFERENCE_PREVIEW_MAX_WORKERS：参考文献预览并发 worker 数。
REFERENCE_PREVIEW_MAX_WORKERS=4
# 中文: NEO4J_URL：Neo4j 图数据库：服务或接口访问地址。
NEO4J_URL=bolt://127.0.0.1:7687
# 中文: NEO4J_USERNAME：Neo4j 图数据库：访问依赖服务的用户名。
NEO4J_USERNAME=neo4j
# 中文: NEO4J_PASSWORD：Neo4j 图数据库：敏感凭据，填写真实密钥、令牌或密码。
NEO4J_PASSWORD=replace-with-neo4j-password

# 中文: QUOTA_CACHE_EPOCH：配额缓存版本号，调整后可整体失效旧缓存。
QUOTA_CACHE_EPOCH=0
# 中文: QUOTA_CONFIG_CACHE_TTL_SECONDS：缓存或凭证有效期。
QUOTA_CONFIG_CACHE_TTL_SECONDS=600
# 中文: QUOTA_ACTIVE_LIST_CACHE_TTL_SECONDS：缓存或凭证有效期。
QUOTA_ACTIVE_LIST_CACHE_TTL_SECONDS=300
# 中文: QUOTA_ALL_LIST_CACHE_TTL_SECONDS：缓存或凭证有效期。
QUOTA_ALL_LIST_CACHE_TTL_SECONDS=300
# 中文: QUOTA_OVERRIDE_CACHE_TTL_SECONDS：缓存或凭证有效期。
QUOTA_OVERRIDE_CACHE_TTL_SECONDS=600
# 中文: CONVERSATION_LIST_CACHE_TTL_SECONDS：对话存储：缓存或凭证有效期。
CONVERSATION_LIST_CACHE_TTL_SECONDS=60
# 中文: CONVERSATION_DETAIL_CACHE_TTL_SECONDS：对话存储：缓存或凭证有效期。
CONVERSATION_DETAIL_CACHE_TTL_SECONDS=30
# 中文: CONVERSATION_DETAIL_CACHE_TOUCH_ON_HIT：对话存储：通用配置项。
CONVERSATION_DETAIL_CACHE_TOUCH_ON_HIT=1
# 中文: CONVERSATION_LIST_RECENT_PAGES_TTL_SECONDS：对话存储：缓存或凭证有效期。
CONVERSATION_LIST_RECENT_PAGES_TTL_SECONDS=900
# 中文: CONVERSATION_LIST_RECENT_PAGES_LIMIT：对话存储：数量、容量或并发限制。
CONVERSATION_LIST_RECENT_PAGES_LIMIT=8
# 中文: QUOTA_LOCK_TTL_SECONDS：缓存或凭证有效期。
QUOTA_LOCK_TTL_SECONDS=30
# 中文: QUOTA_LOCK_WAIT_SECONDS：通用配置项。
QUOTA_LOCK_WAIT_SECONDS=10
# 中文: QUOTA_LOCK_RETRY_INTERVAL_MS：失败重试次数或重试间隔。
QUOTA_LOCK_RETRY_INTERVAL_MS=100

# 中文: UPLOAD_PROCESSING_WORKER_MAX_WORKERS：文件上传：并发 worker 或线程配置。
UPLOAD_PROCESSING_WORKER_MAX_WORKERS=2
# 中文: UPLOAD_PROCESSING_MAX_PDF_PAGES：文件上传：数量、容量或并发限制。
UPLOAD_PROCESSING_MAX_PDF_PAGES=20
# 中文: UPLOAD_PROCESSING_POLL_INTERVAL_MS：文件上传：轮询或同步间隔。
UPLOAD_PROCESSING_POLL_INTERVAL_MS=1000
# 中文: UPLOAD_PROCESSING_RECOVERY_SCAN_LIMIT：文件上传：数量、容量或并发限制。
UPLOAD_PROCESSING_RECOVERY_SCAN_LIMIT=500
# 中文: OUTBOX_WORKER_BATCH_SIZE：数量、容量或并发限制。
OUTBOX_WORKER_BATCH_SIZE=100
# 中文: OUTBOX_WORKER_POLL_INTERVAL_MS：轮询或同步间隔。
OUTBOX_WORKER_POLL_INTERVAL_MS=1000
# 中文: OUTBOX_MAX_ATTEMPTS：数量、容量或并发限制。
OUTBOX_MAX_ATTEMPTS=20
# 中文: OUTBOX_RETRY_BASE_SECONDS：失败重试次数或重试间隔。
OUTBOX_RETRY_BASE_SECONDS=2
# 中文: OUTBOX_RETRY_MAX_SECONDS：失败重试次数或重试间隔。
OUTBOX_RETRY_MAX_SECONDS=300
# 中文: OUTBOX_PROCESSING_TIMEOUT_SECONDS：超时时间配置。
OUTBOX_PROCESSING_TIMEOUT_SECONDS=120
# 中文: DELETED_FILE_CLEANUP_RECONCILE_LIMIT：数量、容量或并发限制。
DELETED_FILE_CLEANUP_RECONCILE_LIMIT=3
# 中文: CONVERSATION_LOCK_TTL_SECONDS：对话存储：缓存或凭证有效期。
CONVERSATION_LOCK_TTL_SECONDS=30
# 中文: CONVERSATION_LOCK_WAIT_SECONDS：对话存储：通用配置项。
CONVERSATION_LOCK_WAIT_SECONDS=10
# 中文: CONVERSATION_LOCK_RETRY_INTERVAL_MS：对话存储：失败重试次数或重试间隔。
CONVERSATION_LOCK_RETRY_INTERVAL_MS=100
