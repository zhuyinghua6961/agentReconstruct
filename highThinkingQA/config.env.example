# Deprecated single-file compatibility template.
# Preferred setup: keep defaults in config.shared.env and local secrets in config.secret.env.

# LLM
# 中文: LLM_API_KEY：大模型：敏感凭据，填写真实密钥、令牌或密码。
LLM_API_KEY=
# 中文: LLM_MODEL：大模型：模型名称。
LLM_MODEL=qwen3-max

# Embedding
# 中文: HIGHTHINKINGQA_EMBEDDING_BASE_URL：深度问答服务：Embedding 接口地址。
HIGHTHINKINGQA_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 中文: HIGHTHINKINGQA_EMBEDDING_MODEL：深度问答服务：Embedding 模型名称。
HIGHTHINKINGQA_EMBEDDING_MODEL=text-embedding-v4
# 中文: HIGHTHINKINGQA_EMBEDDING_DIMENSIONS：深度问答服务：Embedding 向量维度。
HIGHTHINKINGQA_EMBEDDING_DIMENSIONS=2048
# 中文: HIGHTHINKINGQA_EMBEDDING_API_KEY：深度问答服务：敏感凭据，填写真实密钥、令牌或密码。
HIGHTHINKINGQA_EMBEDDING_API_KEY=

# Runtime
# 中文: APP_PORT：服务监听或依赖连接端口。
APP_PORT=8008
# 中文: APP_LOG_LEVEL：应用日志级别，例如 INFO、DEBUG、WARNING。
APP_LOG_LEVEL=INFO
# 中文: CORS_ORIGINS：跨域访问：允许访问的前端来源列表。
CORS_ORIGINS=*
# 中文: GUNICORN_WORKER_CLASS：并发 worker 或线程配置。
GUNICORN_WORKER_CLASS=uvicorn.workers.UvicornWorker
# 中文: GUNICORN_WORKERS：并发 worker 或线程配置。
GUNICORN_WORKERS=2
# 中文: GUNICORN_THREADS：并发 worker 或线程配置。
GUNICORN_THREADS=8
# 中文: GUNICORN_TIMEOUT：超时时间配置。
GUNICORN_TIMEOUT=1800

# Persistence
# 中文: MYSQL_HOST：MySQL 数据库：服务监听或依赖连接主机。
MYSQL_HOST=127.0.0.1
# 中文: MYSQL_PORT：MySQL 数据库：服务监听或依赖连接端口。
MYSQL_PORT=3306
# 中文: MYSQL_USER：MySQL 数据库：访问依赖服务的用户名。
MYSQL_USER=root
# 中文: MYSQL_PASSWORD：MySQL 数据库：敏感凭据，填写真实密钥、令牌或密码。
MYSQL_PASSWORD=change_me
# 中文: MYSQL_DATABASE：MySQL 数据库：数据库名称或数据库编号。
MYSQL_DATABASE=agentcode

# Object storage
# 中文: MINIO_ENDPOINT：MinIO 对象存储：服务或接口访问地址。
MINIO_ENDPOINT=127.0.0.1:9000
# 中文: MINIO_ACCESS_KEY：MinIO 对象存储：敏感凭据，填写真实密钥、令牌或密码。
MINIO_ACCESS_KEY=change_me
# 中文: MINIO_SECRET_KEY：MinIO 对象存储：敏感凭据，填写真实密钥、令牌或密码。
MINIO_SECRET_KEY=change_me
# 中文: MINIO_BUCKET：MinIO 对象存储：对象存储桶、区域或对象路径配置。
MINIO_BUCKET=agentcode
# 中文: MINIO_SECURE：MinIO 对象存储：功能开关，使用 1/0、true/false 控制。
MINIO_SECURE=0

# Auth
# 中文: JWT_SECRET：JWT 认证：敏感凭据，填写真实密钥、令牌或密码。
JWT_SECRET=change_me_for_production
