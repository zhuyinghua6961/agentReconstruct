# Deprecated single-file compatibility template.
# Preferred setup: keep defaults in config.shared.env and local secrets in config.secret.env.

# LLM
DASHSCOPE_API_KEY=your_dashscope_api_key_here
LLM_MODEL=qwen3-max
LLM_ENABLE_THINKING=1
DECOMPOSE_MODEL=qwen3-max
DIRECT_ANSWER_MODEL=qwen3-max
SUB_ANSWER_MODEL=qwen3-max
DIRECT_ANSWER_ENABLE_THINKING=0
DECOMPOSE_ENABLE_THINKING=0

# Runtime
APP_PORT=8008
APP_LOG_LEVEL=INFO
CORS_ORIGINS=*
GUNICORN_WORKER_CLASS=uvicorn.workers.UvicornWorker
GUNICORN_WORKERS=2
GUNICORN_THREADS=8
GUNICORN_TIMEOUT=1800

# Persistence
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=change_me
MYSQL_DATABASE=agentcode

# Object storage
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=change_me
MINIO_SECRET_KEY=change_me
MINIO_BUCKET=agentcode
MINIO_SECURE=0

# Auth
JWT_SECRET=change_me_for_production
