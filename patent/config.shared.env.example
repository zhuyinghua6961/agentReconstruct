# 中文: PATENT_ENV：专利服务：运行模式、命名或路由标识。
PATENT_ENV=dev
# 中文: PATENT_HOST：专利服务：服务监听或依赖连接主机。
PATENT_HOST=0.0.0.0
# 中文: PATENT_PORT：专利服务：服务监听或依赖连接端口。
PATENT_PORT=8787
# 中文: PATENT_GUNICORN_WORKERS：专利服务：并发 worker 或线程配置。
PATENT_GUNICORN_WORKERS=1
# 中文: PATENT_GUNICORN_THREADS：专利服务：并发 worker 或线程配置。
PATENT_GUNICORN_THREADS=8
# 中文: PATENT_GUNICORN_TIMEOUT：专利服务：超时时间配置。
PATENT_GUNICORN_TIMEOUT=120
# 中文: PATENT_GUNICORN_KEEPALIVE：专利服务：通用配置项。
PATENT_GUNICORN_KEEPALIVE=15
# 中文: PATENT_GUNICORN_MAX_REQUESTS：专利服务：数量、容量或并发限制。
PATENT_GUNICORN_MAX_REQUESTS=1000
# 中文: PATENT_GUNICORN_MAX_REQUESTS_JITTER：专利服务：数量、容量或并发限制。
PATENT_GUNICORN_MAX_REQUESTS_JITTER=100
# 中文: PATENT_GUNICORN_WORKER_CLASS：专利服务：并发 worker 或线程配置。
PATENT_GUNICORN_WORKER_CLASS=uvicorn.workers.UvicornWorker
# 中文: PATENT_ASK_STREAM_MAX_CONCURRENT：专利服务：数量、容量或并发限制。
PATENT_ASK_STREAM_MAX_CONCURRENT=8
# 中文: PATENT_ASK_EXECUTOR_MAX_WORKERS：专利服务：并发 worker 或线程配置。
PATENT_ASK_EXECUTOR_MAX_WORKERS=4
# 中文: PATENT_STAGE2_CONVERGENCE_ENABLED：专利服务：功能开关，使用 1/0、true/false 控制。
PATENT_STAGE2_CONVERGENCE_ENABLED=false
# 中文: PATENT_STAGE2_FORCE_KEYWORD_INJECTION：专利 Stage2 检索是否强制注入关键词以提高召回稳定性。
PATENT_STAGE2_FORCE_KEYWORD_INJECTION=true
# 中文: PATENT_STAGE2_ENTITY_LOCK_ENABLED：专利服务：功能开关，使用 1/0、true/false 控制。
PATENT_STAGE2_ENTITY_LOCK_ENABLED=true
# 中文: PATENT_STAGE2_RERANK_CANDIDATES：专利服务：数量、容量或并发限制。
PATENT_STAGE2_RERANK_CANDIDATES=80
# 中文: PATENT_STAGE2_RERANK_TOP_PATENTS：专利 Stage2 重排后保留的专利数量。
PATENT_STAGE2_RERANK_TOP_PATENTS=20
# 中文: PATENT_STAGE2_MIN_RESULTS_PER_CLAIM：专利服务：数量、容量或并发限制。
PATENT_STAGE2_MIN_RESULTS_PER_CLAIM=2
# 中文: PATENT_STAGE2_MAX_RESULTS_PER_CLAIM：专利服务：数量、容量或并发限制。
PATENT_STAGE2_MAX_RESULTS_PER_CLAIM=5
# 中文: PATENT_STAGE2_MAX_GLOBAL_PATENTS：专利服务：数量、容量或并发限制。
PATENT_STAGE2_MAX_GLOBAL_PATENTS=20
# 中文: PATENT_STAGE2_VALIDATION_ENABLED：专利服务：功能开关，使用 1/0、true/false 控制。
PATENT_STAGE2_VALIDATION_ENABLED=true
# 中文: PATENT_STAGE2_C_PATENT_SCORING_ENABLED：专利服务：功能开关，使用 1/0、true/false 控制。
PATENT_STAGE2_C_PATENT_SCORING_ENABLED=false
# 中文: PATENT_STAGE2_C_GLOBAL_CHUNK_RECALL_ENABLED：专利服务：功能开关，使用 1/0、true/false 控制。
PATENT_STAGE2_C_GLOBAL_CHUNK_RECALL_ENABLED=false
# 中文: PATENT_STAGE2_C_TABLE_METRIC_BOOST_ENABLED：专利服务：功能开关，使用 1/0、true/false 控制。
PATENT_STAGE2_C_TABLE_METRIC_BOOST_ENABLED=false
# 中文: PATENT_STAGE4_REFERENCE_TOPK：专利服务：数量、容量或并发限制。
PATENT_STAGE4_REFERENCE_TOPK=20
# 中文: PATENT_STAGE4_MIN_CITATIONS：专利服务：数量、容量或并发限制。
PATENT_STAGE4_MIN_CITATIONS=10
# 中文: 轻量意图模型配置已统一到 resource/config/shared/model-endpoints.shared.env：
# INTENT_MODEL_ENABLED=false
# INTENT_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# INTENT_MODEL=qwen3-8b
# INTENT_MODEL_TIMEOUT_SECONDS=30
# 敏感 key 放在 resource/config/shared/model-endpoints.secret.env 的 INTENT_MODEL_API_KEY。
# 中文: PATENT_REDIS_URL：Redis 缓存：服务或接口访问地址。
PATENT_REDIS_URL=redis://localhost:6379/0
# 中文: PATENT_REDIS_KEY_PREFIX：Redis 缓存：运行模式、命名或路由标识。
PATENT_REDIS_KEY_PREFIX=patent
# 中文: PATENT_REDIS_SOCKET_CONNECT_TIMEOUT_SEC：Redis 缓存：超时时间配置。
PATENT_REDIS_SOCKET_CONNECT_TIMEOUT_SEC=1.5
# 中文: PATENT_REDIS_SOCKET_TIMEOUT_SEC：Redis 缓存：超时时间配置。
PATENT_REDIS_SOCKET_TIMEOUT_SEC=1.5
# 中文: PATENT_AUTHORITY_BASE_URL：专利服务：服务或接口访问地址。
PATENT_AUTHORITY_BASE_URL=http://public-service
# 中文: PATENT_AUTHORITY_TIMEOUT_SECONDS：专利服务：超时时间配置。
PATENT_AUTHORITY_TIMEOUT_SECONDS=10
# 中文: PATENT_AUTHORITY_INTERNAL_TOKEN：专利服务：敏感凭据，填写真实密钥、令牌或密码。
PATENT_AUTHORITY_INTERNAL_TOKEN=
# 中文: PATENT_DURABLE_AUTHORITY_ENABLED：专利服务：功能开关，使用 1/0、true/false 控制。
PATENT_DURABLE_AUTHORITY_ENABLED=false
# 中文: PATENT_DURABLE_MODE_ENABLED：专利服务：功能开关，使用 1/0、true/false 控制。
PATENT_DURABLE_MODE_ENABLED=false
# 中文: PATENT_GRAPH_KB_TIMEOUT_MS：专利服务：超时时间配置。
PATENT_GRAPH_KB_TIMEOUT_MS=3000
# 中文: PATENT_GRAPH_KB_MAX_ROWS：专利服务：数量、容量或并发限制。
PATENT_GRAPH_KB_MAX_ROWS=20
# 中文: PATENT_GRAPH_KB_QUERY_LOGGING：专利服务：功能开关，使用 1/0、true/false 控制。
PATENT_GRAPH_KB_QUERY_LOGGING=false
# 中文: PATENT_NEO4J_URL：Neo4j 图数据库：服务或接口访问地址。
PATENT_NEO4J_URL=bolt://127.0.0.1:8687
# 中文: PATENT_NEO4J_DATABASE：Neo4j 图数据库：数据库名称或数据库编号。
PATENT_NEO4J_DATABASE=neo4j
# 中文: PATENT_NEO4J_USERNAME：Neo4j 图数据库：访问依赖服务的用户名。
PATENT_NEO4J_USERNAME=neo4j
# 中文: PATENT_TABULAR_TOP_P：专利服务：模型采样或评分阈值。
PATENT_TABULAR_TOP_P=0.95
# 中文: PATENT_TABULAR_MAX_TOKENS：专利服务：敏感凭据，填写真实密钥、令牌或密码。
PATENT_TABULAR_MAX_TOKENS=2500
# 中文: PATENT_TABULAR_MAX_CONTEXT_CHARS：专利服务：数量、容量或并发限制。
PATENT_TABULAR_MAX_CONTEXT_CHARS=12000
# 中文: PATENT_HYBRID_TABLE_CONTEXT_CHARS：专利服务：通用配置项。
PATENT_HYBRID_TABLE_CONTEXT_CHARS=6000
# 中文: PATENT_HYBRID_MAX_TOKENS：专利服务：敏感凭据，填写真实密钥、令牌或密码。
PATENT_HYBRID_MAX_TOKENS=3000
# 中文: PATENT_LLM_HTTP_CONNECT_TIMEOUT_SECONDS：专利服务：超时时间配置。
PATENT_LLM_HTTP_CONNECT_TIMEOUT_SECONDS=15
# 中文: PATENT_LLM_HTTP_READ_TIMEOUT_SECONDS：专利服务：超时时间配置。
PATENT_LLM_HTTP_READ_TIMEOUT_SECONDS=180
# 中文: PATENT_LLM_HTTP_STREAM_READ_TIMEOUT_SECONDS：专利服务：超时时间配置。
PATENT_LLM_HTTP_STREAM_READ_TIMEOUT_SECONDS=600
# 中文: PATENT_LLM_HTTP_WRITE_TIMEOUT_SECONDS：专利服务：超时时间配置。
PATENT_LLM_HTTP_WRITE_TIMEOUT_SECONDS=180
# 中文: PATENT_LLM_HTTP_POOL_TIMEOUT_SECONDS：专利服务：超时时间配置。
PATENT_LLM_HTTP_POOL_TIMEOUT_SECONDS=30
# 中文: PATENT_LLM_HTTP_KEEPALIVE_EXPIRY_SECONDS：专利服务上游 LLM HTTP 连接池空闲连接保活时间，单位秒。
PATENT_LLM_HTTP_KEEPALIVE_EXPIRY_SECONDS=120
# 中文: PATENT_LLM_HTTP_MAX_KEEPALIVE_CONNECTIONS：专利服务：数量、容量或并发限制。
PATENT_LLM_HTTP_MAX_KEEPALIVE_CONNECTIONS=20
# 中文: PATENT_LLM_HTTP_MAX_CONNECTIONS：专利服务：数量、容量或并发限制。
PATENT_LLM_HTTP_MAX_CONNECTIONS=100
# 中文: PATENT_PLANNING_HOT_POOL_LANE_COUNT：专利服务：数量、容量或并发限制。
PATENT_PLANNING_HOT_POOL_LANE_COUNT=2
# 中文: PATENT_PLANNING_HOT_POOL_LANE_DEGRADED_AFTER_SECONDS：规划热池通道多久未健康后视为降级，单位秒。
PATENT_PLANNING_HOT_POOL_LANE_DEGRADED_AFTER_SECONDS=7200
# 中文: PATENT_INTENT_ANCHOR_EXTRACT_ENABLED：意图识别是否同时抽取检索锚词并注入 Stage1 claims。
PATENT_INTENT_ANCHOR_EXTRACT_ENABLED=true
# 中文: PATENT_INTENT_ANCHOR_MAX_TERMS：意图/规则合并后的检索锚词上限。
PATENT_INTENT_ANCHOR_MAX_TERMS=12
# 中文: PATENT_STAGE1_CLAIM_KEYWORDS_MAX：每条 retrieval_claim keywords 上限。
PATENT_STAGE1_CLAIM_KEYWORDS_MAX=12
# 中文: JWT_EXPIRE_SECONDS：JWT 认证：缓存或凭证有效期。
JWT_EXPIRE_SECONDS=86400
# 中文: JWT_COMPATIBLE_ACCESS_SALTS：JWT 认证：通用配置项。
JWT_COMPATIBLE_ACCESS_SALTS=agentcode.auth.access
