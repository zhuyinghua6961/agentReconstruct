# ============================================================================
# Public runtime config (safe to commit)
# ============================================================================
# Commit this file. Keep credentials in config.secret.env or legacy .env/config.env.
# Load order: config.env -> config.shared.env -> config.secret.env -> .env
# ============================================================================

# LLM / embedding / OCR defaults
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3-max
LLM_ENABLE_THINKING=1
DECOMPOSE_MODEL=qwen3-max
DIRECT_ANSWER_MODEL=qwen3-max
SUB_ANSWER_MODEL=qwen3-max
DIRECT_ANSWER_ENABLE_THINKING=0
DECOMPOSE_ENABLE_THINKING=0
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=2048
OCR_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OCR_MODEL=qwen-vl-ocr-2025-11-20

# Chunking / retrieval
MAX_CHUNK_TOKENS=4000
SEMANTIC_CHUNK_MIN_TOKENS=2000
SEMANTIC_CHUNK_MAX_TOKENS=4000
TIKTOKEN_ENCODING=cl100k_base
RETRIEVAL_TOP_K=3
RETRIEVAL_PIPELINE_BATCH_SIZE=2
NUM_SUB_QUESTIONS=5
CHECKER_MODEL=qwen3.5-plus
MAX_CHECK_LOOPS=2

# Ingestion concurrency
OCR_CONCURRENCY=40
OCR_MAX_CONCURRENT_REQUESTS=40
OCR_PAGES_PER_BATCH=3
OCR_MAX_RETRIES=5
OCR_RETRY_BASE=3
EMBED_BATCH_SIZE=10
EMBED_API_RPM=1800
EMBED_API_TPM=1200000
EMBED_CONCURRENCY=2
EMBED_MAX_CONCURRENT_REQUESTS=4
EMBED_MAX_INPUT_TOKENS=8000
EMBED_MAX_RETRIES=5
EMBED_QUEUE_SIZE=200

# Local paths
PAPERS_DIR=papers
PROMPTS_DIR=prompts
CHROMA_PERSIST_DIR=vectordb
CHROMA_COLLECTION_NAME=lfp_papers
UPLOAD_DIR=uploads
CHAT_JSON_BASE_DIR=data/conversations
CHAT_JSON_STORAGE_PREFIX=conversations

# HTTP runtime defaults
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8008
APP_LOG_LEVEL=INFO
BACKEND_SERVER=gunicorn
GUNICORN_WORKER_CLASS=uvicorn.workers.UvicornWorker
GUNICORN_WORKERS=2
GUNICORN_THREADS=8
GUNICORN_TIMEOUT=1800
GUNICORN_KEEPALIVE=15
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=100
ENABLE_CORS=1
CORS_ORIGINS=*
ASK_STREAM_MAX_CONCURRENT=5
ASK_EXECUTOR_MAX_WORKERS=5
ASK_TIMEOUT_SECONDS=1800
SSE_HEARTBEAT_SECONDS=15
CHAT_PERSIST_ENABLED=1
CHAT_PERSIST_ASYNC=1
CHAT_PERSIST_ASYNC_WORKERS=4

# Auth / storage / persistence defaults
JWT_EXPIRE_SECONDS=86400
PASSWORD_EXPIRE_DAYS=180
LOGIN_FAILURE_LOCK_THRESHOLD=5
LOGIN_FAILURE_LOCK_MINUTES=5
MAX_PDF_PAGES=50
